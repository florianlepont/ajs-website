{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/feedback/**",
              "components/forms/**",
              "components/gallery/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo Black))/i]",
        "message": "Font not provided by the design system. Available: Archivo Black."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|body|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: heading, body."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: text."
      },
      {
        "selector": "JSXOpeningElement[name.name='GalleryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|imageSrc|imageAlt|href|ctaLabel|key|ref|className|style|children)$/]",
        "message": "<GalleryCard> doesn't accept that prop. Declared props: title, imageSrc, imageAlt, href, ctaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:siteTitle|logoSrc|locale|homeLabel|navLabel|switcher|transparent|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: siteTitle, logoSrc, locale, homeLabel, navLabel, switcher, transparent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute[name.name='locale'] > Literal[value!=/^(?:fr|en)$/]",
        "message": "<Header> locale must be one of 'fr' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='LanguageSwitcher'] > JSXAttribute > JSXIdentifier[name!=/^(?:locale|hrefFr|hrefEn|color|key|ref|className|style|children)$/]",
        "message": "<LanguageSwitcher> doesn't accept that prop. Declared props: locale, hrefFr, hrefEn, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='LanguageSwitcher'] > JSXAttribute[name.name='locale'] > Literal[value!=/^(?:fr|en)$/]",
        "message": "<LanguageSwitcher> locale must be one of 'fr' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Lightbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:imageSrc|imageAlt|index|total|onClose|onPrev|onNext|key|ref|className|style|children)$/]",
        "message": "<Lightbox> doesn't accept that prop. Declared props: imageSrc, imageAlt, index, total, onClose, onPrev, onNext."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, error."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
      },
      "EmptyState": {
        "replaces": []
      },
      "Footer": {
        "replaces": []
      },
      "GalleryCard": {
        "replaces": []
      },
      "Header": {
