---
// Shared chrome (header + footer sourced from the Sanity siteSettings
// singleton) plus the D-03 pre-paint locale-cookie redirect. Both locale
// variants (`/` and `/en/`) render this exact same layout — only the copy
// differs (UI-SPEC Layout Notes).
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getSiteSettings } from '../lib/sanity';
import { resolveSiteCopy } from '../lib/site-config';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
// D-02/RESEARCH.md Pattern 1: self-hosted Unbounded, 900 (black) weight only
// (Heading/Display role) — bundles the woff2 + @font-face at build time, no
// Google Fonts CDN request (Pitfall 1 — keeps the shipped privacy policy's
// data-flow enumeration accurate). Swapped from Anton per direct user
// feedback (referencing mockplus.com's brutalist-fonts roundup): Anton was
// itself a swap from Archivo Black (a self-flagged, unresearched placeholder
// — .planning/design-import/design-system/tokens/fonts.css) via the
// logo-hover-and-font debug session. The specific font the user pointed to
// (#14 in that roundup, "Damian Uniqua") turned out to be a Creative Fabrica
// font with unverified commercial/web-embedding license terms — too risky
// for a site that sells art — so this is a free-license (SIL OFL 1.1, same
// as Anton) Google Font lookalike instead: Unbounded is explicitly designed
// with brutalist/constructivist influence (geometric, distinctively
// rounded-cut corners), matching the "unique curves and bold strokes"
// character the user was pointing at. Only the 900 (black) weight is
// imported/loaded — every --font-display consumer already declares
// font-weight: var(--weight-semibold) (600), but since 900 is the only
// weight file loaded, the browser renders that single loaded weight
// regardless of the declared number (identical behavior to how the
// single-weight Anton import worked before it).
import '@fontsource/unbounded/900.css';

interface Props {
  title: string;
  // D-11/D-13/RESEARCH.md Architectural Responsibility Map: 'solid' (default)
  // is every existing page's white-on-white hairline header; 'transparent'
  // is the gallery-detail hero-scrim header (Plan 04.1-05, D-07); 'none'
  // suppresses the shared header entirely for the homepage's own overlaid
  // top bar (Plan 04.1-04). The shared <footer> always renders regardless.
  headerVariant?: 'solid' | 'transparent' | 'none';
}

const { title, headerVariant = 'solid' } = Astro.props;
const locale = Astro.currentLocale === 'en' ? 'en' : 'fr';

const siteSettings = await getSiteSettings();
// WR-03: chain all the way to each leaf — a document written outside the
// Studio's publish-time validation (e.g. via a script calling the API
// directly, as this project's own seed content was) can be truthy but
// partially populated, and this runs in frontmatter at build time, so an
// unguarded nested access here would fail the entire site build.
const siteTitle = siteSettings?.siteTitle?.[locale] ?? 'Atelier Jacqueline Suzanne';
const footerText = siteSettings?.footerText?.[locale] ?? '';
const siteCopy = resolveSiteCopy(siteSettings, locale);
// homeHref is still needed below for the logo's own link — no separate
// "Accueil"/"Home" nav link anymore (direct user feedback: redundant,
// since clicking the logo already goes home).
const homeHref = getRelativeLocaleUrl(locale, '');
// Current navigation labels are editable in the siteSettings singleton.
const aboutLabel = siteCopy.aboutLabel;
const aboutHref = getRelativeLocaleUrl(locale, 'about');
const contactLabel = siteCopy.contactLabel;
const contactHref = getRelativeLocaleUrl(locale, 'contact');
// Legal pages (Phase 4, D-06): footer-only links, every page, not scoped to
// About/Contact. Same hardcoded locale-conditional pattern as above — legal
// copy is not CMS-editable (RESEARCH.md "Don't Hand-Roll"). Legal notice
// link shipped in Plan 04-01; Confidentialité/Privacy link appended in Plan
// 04-02, after the legal-notice link (UI-SPEC footer link order).
const legalNoticeLabel = locale === 'en' ? 'Legal notice' : 'Mentions légales';
const legalNoticeHref = getRelativeLocaleUrl(locale, 'mentions-legales');
const privacyLabel = locale === 'en' ? 'Privacy' : 'Confidentialité';
const privacyHref = getRelativeLocaleUrl(locale, 'confidentialite');
// Phase 04.2 (SOCIAL-01): site-wide footer Instagram link. Absolute external
// URL — does NOT go through getRelativeLocaleUrl (that helper is only for
// internal/site-relative routes).
const instagramNewTabHint = locale === 'en' ? ' (opens in new tab)' : ' (nouvelle fenêtre)';

// D-11: real AJS wordmark PNG logo, header only. Base-aware (matches the
// CR-01 precedent, 01-REVIEW.md) so the asset resolves correctly under
// GitHub Pages' non-root base as well as OVH's root base.
const assetBase = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const logoBlackSrc = `${assetBase}/logos/AJS_Brutalist_Black_Transparent.png`;
const logoWhiteSrc = `${assetBase}/logos/AJS_Brutalist_White_Transparent.png`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
      // D-03: no server/middleware exists on OVH static hosting to read
      // cookies, so a returning visitor's locale preference is honored via a
      // render-blocking (is:inline, not deferred) same-origin redirect,
      // before paint, to minimize flash-of-wrong-locale content.
      //
      // `base` (e.g. "/ajs-website/" on GitHub Pages, "/" on OVH production)
      // is inlined at build time via `define:vars` so the redirect targets
      // the correct deployed path instead of assuming the site is served
      // from the domain root.
      (function () {
        var COOKIE_NAME = 'ajs_locale';
        var match = document.cookie.match(new RegExp('(?:^|; )' + COOKIE_NAME + '=([^;]*)'));
        var preferred = match ? decodeURIComponent(match[1]) : null;
        var basePath = base.endsWith('/') ? base : base + '/';
        var pathAfterBase = location.pathname.startsWith(basePath)
          ? location.pathname.slice(basePath.length - 1)
          : location.pathname;
        var onFrenchRootPage = !pathAfterBase.startsWith('/en/');
        if (preferred === 'en' && onFrenchRootPage) {
          location.replace(basePath.slice(0, -1) + '/en' + pathAfterBase);
        }
      })();
    </script>
  </head>
  <body>
    {headerVariant !== 'none' && (
      <header class:list={['chrome-band', 'site-header', `site-header--${headerVariant}`]}>
        <a href={homeHref} class="logo-mark" aria-label={siteTitle}>
          <span class="logo-mark__chip" aria-hidden="true"></span>
          <img src={logoBlackSrc} alt="" class="logo-mark__img logo-mark__img--default" />
          <img src={logoWhiteSrc} alt="" class="logo-mark__img logo-mark__img--hover" />
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={aboutHref} class="nav-link">{aboutLabel}</a>
          <a href={contactHref} class="nav-link">{contactLabel}</a>
        </nav>
        <LanguageSwitcher />
      </header>
    )}
    <main>
      <slot />
    </main>
    <footer class="chrome-band">
      <p class="footer-text">{footerText}</p>
      <nav class="footer-legal-nav" aria-label="Legal">
        <a href={legalNoticeHref} class="nav-link">{legalNoticeLabel}</a>
        <a href={privacyHref} class="nav-link">{privacyLabel}</a>
      </nav>
      <nav class="footer-social-nav" aria-label="Social">
        <a
          href={siteCopy.instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link"
        >
          Instagram<span class="sr-only">{instagramNewTabHint}</span>
        </a>
      </nav>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* White / Ink / Pop-Pink — Phase 04.1 rebrand, supersedes Phase 2's
       prior palette and dormant fallback-only display typeface
       (04.1-UI-SPEC.md Color; values are authoritative per
       .planning/design-import/design-system/tokens/colors.css). */
    --gray-0: #FFFFFF;
    --gray-900: #1A1A1A;
    --pink-600: #FF3B94;

    /* Decorative palette — homepage hero-carousel-only (D-05), never used
       for functional/interactive UI elsewhere on the site. */
    --palette-purple: #AF3DFF;
    --palette-teal: #55FFE1;
    --palette-lime: #A6FD29;
    --palette-plum: #37013A;

    /* Semantic aliases */
    --color-dominant: var(--gray-0);
    --color-secondary: var(--gray-0); /* D-04: merged into dominant — header/footer are white-on-white */
    --color-accent: var(--pink-600);
    --color-ink: var(--gray-900);
    --color-border: #E3E1DE;
    --color-on-accent: var(--gray-900); /* D-01/UI-SPEC Color: ink, not white, on accent-pink fills */
    --color-link: var(--color-accent);
    --color-link-hover: var(--color-accent);
    --color-focus-ring: var(--color-accent);
    /* The destructive-red semantic token is removed entirely (D-03) —
       ink-only error convention (bold ink text + thicker ink border)
       replaces it. */

    /* Typography roles (04.1-UI-SPEC.md Typography) */
    --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    --font-display: 'Unbounded', var(--font-sans);
    --weight-regular: 400;
    --weight-semibold: 600;

    --text-label-size: 14px;
    --text-label-weight: var(--weight-regular);
    --text-label-leading: 1.5;

    --text-body-size: 16px;
    --text-body-weight: var(--weight-regular);
    --text-body-leading: 1.5;

    --text-heading-size: 20px;
    --text-heading-weight: var(--weight-semibold);
    --text-heading-leading: 1.2;
    --text-heading-family: var(--font-display);

    --text-display-size: 32px;
    --text-display-weight: var(--weight-semibold);
    --text-display-leading: 1.2;
    --text-display-family: var(--font-display);

    /* Radii / borders (04.1-UI-SPEC.md Spacing Scale exceptions) */
    --radius-none: 0px;
    --radius-sm: 2px;
    --border-hairline: 1px;
    --border-focus: 2px;
    --focus-ring-offset: 2px;
    --tap-target-min: 44px;

    --space-xs: 4px;
    --space-sm: 8px;
    --space-md: 16px;
    --space-lg: 24px;
    --space-xl: 32px;
    --space-2xl: 48px;
    --space-3xl: 64px;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  body {
    font-family: var(--font-sans); /* Archivo is display-only, per UI-SPEC Typography */
    font-weight: var(--weight-regular);
    background-color: var(--color-dominant);
    color: var(--color-ink);
  }

  /* D-06: links render as full pink text, not ink-text-plus-underline. */
  a {
    color: var(--color-accent);
    text-decoration: none;
  }

  a:hover,
  a:focus-visible {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  /* Single pink focus ring (D-06/UI-SPEC Color, link hover/focus states) —
     pink-on-white passes contrast, so the double ink+accent ring from the
     superseded identity is no longer needed. */
  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--focus-ring-offset);
  }

  /* Visually-hidden but screen-reader-available utility (introduced here for
     reuse by GalleryCard in Plan 03). */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<style>
  /* D-04: header/footer merge onto --color-dominant (white-on-white),
     delineated only by a 1px hairline border — no chrome-band tint. */
  .chrome-band {
    padding: var(--space-lg) var(--space-md);
  }

  @media (min-width: 768px) {
    .chrome-band {
      padding: var(--space-xl) var(--space-md);
    }
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .site-header--solid {
    background-color: var(--color-dominant);
    border-bottom: var(--border-hairline) solid var(--color-border);
  }

  /* D-07/Plan 04.1-05: absolutely-positioned, transparent/gradient header
     over a hero photo scrim — no hairline border (the scrim itself is the
     delineation). Nav text renders white in this variant. */
  .site-header--transparent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.25) 60%, rgba(0, 0, 0, 0) 100%);
  }

  .site-header--transparent .nav-link {
    color: #FFFFFF;
  }

  /* D-11/D-13/RESEARCH.md Pattern 3 (revised per logo-hover-and-font debug
     session): two normal-flow <img> elements, hard display:none/block swap
     on hover — matches the reference site's own hover MECHANIC exactly
     (verified byte-for-byte against its compiled CSS: `.image-link` is
     `display: inline-block`, `.image-rollover` is `display: none` by
     default, swapped on hover, no transition/opacity). Deliberately NOT
     absolutely-positioned: an earlier version of this fix stacked the hover
     image with `position: absolute` while the default image used
     `display: none` on hover, which collapsed `.logo-mark`'s own box to 0x0
     (no in-flow child left) and shifted the sibling nav layout on hover.
     Both logo PNGs share the same intrinsic aspect ratio, so swapping which
     one is in-flow causes no layout jump.

     The dark `__chip` backdrop is KEPT (unlike the original fix plan) but
     changed from an opacity-fade to the same instant display:none/block
     toggle as the images — verified by downloading the reference site's own
     rollover PNG asset (not just its CSS) that its "hover" logo has an
     opaque black background baked directly into the image file, which is
     how it stays legible over the white header. Our white logo variant
     (AJS_Brutalist_White_Transparent.png) is transparent, so without an
     instant backdrop behind it, the hover state is nearly invisible against
     a light header — reproducing the reference's CSS literally without this
     would visually regress legibility versus both the reference site and
     the pre-fix implementation. */
  .logo-mark {
    position: relative;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-mark__chip {
    position: absolute;
    inset: calc(-1 * var(--space-sm));
    background-color: var(--color-ink);
    border-radius: var(--radius-none);
    display: none;
    z-index: 0;
  }

  .logo-mark__img {
    position: relative;
    z-index: 1;
    display: block;
    width: 56px;
    height: auto;
  }

  .logo-mark__img--hover {
    display: none;
  }

  /* Solid header: default = black logo; hover/focus-within hard-swaps to the
     white variant over the instantly-shown dark chip, no transition. */
  .site-header--solid .logo-mark:hover .logo-mark__img--default,
  .site-header--solid .logo-mark:focus-within .logo-mark__img--default {
    display: none;
  }

  .site-header--solid .logo-mark:hover .logo-mark__img--hover,
  .site-header--solid .logo-mark:focus-within .logo-mark__img--hover,
  .site-header--solid .logo-mark:hover .logo-mark__chip,
  .site-header--solid .logo-mark:focus-within .logo-mark__chip {
    display: block;
  }

  /* Transparent header (revised per logo-hover-and-font debug session, Round
     2): white logo variant shown by default (over the dark scrim already
     provided by the header background) — unchanged. Hover/focus-within now
     hard-swaps to the BLACK variant, same mechanic as the solid header, but
     with a LIGHT chip instead of the solid header's dark chip — the black
     hover-logo would be invisible against both the dark scrim and a dark
     chip, so the backdrop color must flip with the logo color, not stay
     fixed. Used on gallery-detail pages (dark hero background) as well as
     any other transparent-header page. */
  .site-header--transparent .logo-mark__img--default {
    display: none;
  }

  .site-header--transparent .logo-mark__img--hover {
    display: block;
  }

  .site-header--transparent .logo-mark:hover .logo-mark__img--hover,
  .site-header--transparent .logo-mark:focus-within .logo-mark__img--hover {
    display: none;
  }

  .site-header--transparent .logo-mark:hover .logo-mark__img--default,
  .site-header--transparent .logo-mark:focus-within .logo-mark__img--default,
  .site-header--transparent .logo-mark:hover .logo-mark__chip,
  .site-header--transparent .logo-mark:focus-within .logo-mark__chip {
    display: block;
  }

  /* Mode-aware chip color: solid header's chip (behind the white hover-logo)
     stays dark (--color-ink, the base .logo-mark__chip rule above) — this
     override only applies inside the transparent header, behind the black
     hover-logo, so it must be light instead. */
  .site-header--transparent .logo-mark__chip {
    background-color: var(--color-dominant);
  }

  .site-nav {
    margin-right: auto;
    margin-left: var(--space-md);
    display: flex;
    gap: var(--space-md);
  }

  .nav-link {
    font-size: 14px; /* Label role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    text-decoration: underline;
  }

  footer.chrome-band {
    text-align: left;
    border-top: var(--border-hairline) solid var(--color-border);
  }

  .footer-text {
    margin: 0;
    font-size: 14px; /* Label role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
  }

  .footer-legal-nav {
    display: flex;
    gap: var(--space-xl);
    margin-top: var(--space-md);
  }

  .footer-social-nav {
    display: flex;
    gap: var(--space-xl);
    margin-top: var(--space-md);
  }

  main {
    background-color: var(--color-dominant);
  }
</style>
