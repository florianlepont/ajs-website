---
// Shared chrome (header + footer sourced from the Sanity siteSettings
// singleton) plus the D-03 pre-paint locale-cookie redirect. Both locale
// variants (`/` and `/en/`) render this exact same layout — only the copy
// differs (UI-SPEC Layout Notes).
import { getSiteSettings } from '../lib/sanity';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = Astro.currentLocale === 'en' ? 'en' : 'fr';

const siteSettings = await getSiteSettings();
const siteTitle = siteSettings?.siteTitle[locale] ?? 'Atelier Jacqueline Suzanne';
const footerText = siteSettings?.footerText[locale] ?? '';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // D-03: no server/middleware exists on OVH static hosting to read
      // cookies, so a returning visitor's locale preference is honored via a
      // render-blocking (is:inline, not deferred) same-origin redirect,
      // before paint, to minimize flash-of-wrong-locale content.
      (function () {
        var COOKIE_NAME = 'ajs_locale';
        var match = document.cookie.match(new RegExp('(?:^|; )' + COOKIE_NAME + '=([^;]*)'));
        var preferred = match ? decodeURIComponent(match[1]) : null;
        var onFrenchRootPage = !location.pathname.startsWith('/en/');
        if (preferred === 'en' && onFrenchRootPage) {
          location.replace('/en' + location.pathname);
        }
      })();
    </script>
  </head>
  <body>
    <header class="chrome-band">
      <p class="site-title">{siteTitle}</p>
      <LanguageSwitcher />
    </header>
    <main>
      <slot />
    </main>
    <footer class="chrome-band">
      <p class="footer-text">{footerText}</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-dominant: #ffffff;
    --color-secondary: #f5f4f2;
    --color-accent: #1a1a1a;
    --color-destructive: #dc2626; /* reserved for later phases, unused this phase */

    --space-xs: 4px;
    --space-sm: 8px;
    --space-md: 16px;
    --space-lg: 24px;
    --space-xl: 32px;
    --space-2xl: 48px;
    --space-3xl: 64px;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  body {
    font-family:
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      Helvetica,
      Arial,
      sans-serif;
    background-color: var(--color-dominant);
    color: var(--color-accent);
  }

  a {
    color: var(--color-accent);
  }

  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

<style>
  .chrome-band {
    background-color: var(--color-secondary);
    padding: var(--space-lg) var(--space-md);
  }

  @media (min-width: 768px) {
    .chrome-band {
      padding: var(--space-xl) var(--space-md);
    }
  }

  header.chrome-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .site-title {
    margin: 0;
    font-size: 20px; /* Heading role */
    font-weight: 600;
    line-height: 1.2;
  }

  footer.chrome-band {
    text-align: left;
  }

  .footer-text {
    margin: 0;
    font-size: 14px; /* Label role */
    font-weight: 400;
    line-height: 1.5;
  }

  main {
    background-color: var(--color-dominant);
  }
</style>
