---
// Shared chrome (header + footer sourced from the Sanity siteSettings
// singleton) plus the D-03 pre-paint locale-cookie redirect. Both locale
// variants (`/` and `/en/`) render this exact same layout — only the copy
// differs (UI-SPEC Layout Notes).
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getSiteSettings } from '../lib/sanity';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = Astro.currentLocale === 'en' ? 'en' : 'fr';

const siteSettings = await getSiteSettings();
// WR-03: chain all the way to each leaf — a document written outside the
// Studio's publish-time validation (e.g. via a script calling the API
// directly, as this project's own seed content was) can be truthy but
// partially populated, and this runs in frontmatter at build time, so an
// unguarded nested access here would fail the entire site build.
const siteTitle = siteSettings?.siteTitle?.[locale] ?? 'Atelier Jacqueline Suzanne';
const footerText = siteSettings?.footerText?.[locale] ?? '';
const homeLabel = siteSettings?.navLabels?.home?.[locale] ?? (locale === 'en' ? 'Home' : 'Accueil');
const homeHref = getRelativeLocaleUrl(locale, '');
// WR-03: defensive fallback — navLabels.galleries is Studio-required (fr/en)
// per 02-01's schema validation, but a document written outside the
// Studio's publish-time validation could still be partially populated.
const galleriesLabel =
  siteSettings?.navLabels?.galleries?.[locale] ?? (locale === 'en' ? 'Galleries' : 'Galeries');
const galleriesHref = getRelativeLocaleUrl(locale, 'galleries');
// About content is not in CMS scope (CMS-01 is galleries-only), so this
// label is a hardcoded locale conditional rather than a Sanity navLabels
// field.
const aboutLabel = locale === 'en' ? 'About' : 'À propos';
const aboutHref = getRelativeLocaleUrl(locale, 'about');
// Contact content is likewise outside CMS-01's galleries-only scope.
const contactLabel = locale === 'en' ? 'Contact' : 'Contact';
const contactHref = getRelativeLocaleUrl(locale, 'contact');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
      // D-03: no server/middleware exists on OVH static hosting to read
      // cookies, so a returning visitor's locale preference is honored via a
      // render-blocking (is:inline, not deferred) same-origin redirect,
      // before paint, to minimize flash-of-wrong-locale content.
      //
      // `base` (e.g. "/ajs-website/" on GitHub Pages, "/" on OVH production)
      // is inlined at build time via `define:vars` so the redirect targets
      // the correct deployed path instead of assuming the site is served
      // from the domain root.
      (function () {
        var COOKIE_NAME = 'ajs_locale';
        var match = document.cookie.match(new RegExp('(?:^|; )' + COOKIE_NAME + '=([^;]*)'));
        var preferred = match ? decodeURIComponent(match[1]) : null;
        var basePath = base.endsWith('/') ? base : base + '/';
        var pathAfterBase = location.pathname.startsWith(basePath)
          ? location.pathname.slice(basePath.length - 1)
          : location.pathname;
        var onFrenchRootPage = !pathAfterBase.startsWith('/en/');
        if (preferred === 'en' && onFrenchRootPage) {
          location.replace(basePath.slice(0, -1) + '/en' + pathAfterBase);
        }
      })();
    </script>
  </head>
  <body>
    <header class="chrome-band">
      <p class="site-title">{siteTitle}</p>
      <nav class="site-nav" aria-label="Primary">
        <a href={homeHref} class="nav-link">{homeLabel}</a>
        <a href={galleriesHref} class="nav-link">{galleriesLabel}</a>
        <a href={aboutHref} class="nav-link">{aboutLabel}</a>
        <a href={contactHref} class="nav-link">{contactLabel}</a>
      </nav>
      <LanguageSwitcher />
    </header>
    <main>
      <slot />
    </main>
    <footer class="chrome-band">
      <p class="footer-text">{footerText}</p>
    </footer>
  </body>
</html>

<style is:global>
  /* Delight variable font (100-900 weight axis), self-hosted per UI-SPEC —
     the system-font stack below remains a fully functional fallback until
     the licensed file lands at public/fonts/delight.woff2 (Task 2). */
  @font-face {
    font-family: 'Delight';
    src: url('/fonts/delight.woff2') format('woff2');
    font-weight: 100 900;
    font-display: swap;
  }

  :root {
    /* Dawn Pink / Woodsmoke / Wild Strawberry — real visual identity,
       supersedes Phase 1's provisional grayscale (02-UI-SPEC.md Color). */
    --color-dominant: #F0E7E4;
    --color-secondary: #E4D9D0;
    --color-accent: #F92D97;
    --color-ink: #141213;
    --color-destructive: #dc2626; /* reserved for later phases, unused this phase */

    --space-xs: 4px;
    --space-sm: 8px;
    --space-md: 16px;
    --space-lg: 24px;
    --space-xl: 32px;
    --space-2xl: 48px;
    --space-3xl: 64px;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  body {
    font-family:
      'Delight',
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      Helvetica,
      Arial,
      sans-serif;
    font-weight: 300; /* Body/Label role default — Heading/Display opt into 900 */
    background-color: var(--color-dominant);
    color: var(--color-ink);
  }

  /* Wild Strawberry text fails WCAG contrast on Dawn Pink (~2.95:1), so links
     keep the compliant Woodsmoke glyph color and carry the accent only via a
     permanent underline cue (02-UI-SPEC.md Color, contrast resolution). */
  a {
    color: var(--color-ink);
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
  }

  /* Co-styled double ring: the compliant Woodsmoke outline plus a Wild
     Strawberry ring just outside it (bare accent-only outline fails the same
     ~2.95:1 non-text contrast check as link text). */
  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: 2px;
    box-shadow: 0 0 0 4px var(--color-accent);
  }

  /* Visually-hidden but screen-reader-available utility (introduced here for
     reuse by GalleryCard in Plan 03). */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<style>
  .chrome-band {
    background-color: var(--color-secondary);
    padding: var(--space-lg) var(--space-md);
  }

  @media (min-width: 768px) {
    .chrome-band {
      padding: var(--space-xl) var(--space-md);
    }
  }

  header.chrome-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .site-title {
    margin: 0;
    font-size: 20px; /* Heading role */
    font-weight: 900;
    line-height: 1.2;
  }

  .site-nav {
    margin-right: auto;
    margin-left: var(--space-md);
    display: flex;
    gap: var(--space-md);
  }

  .nav-link {
    font-size: 14px; /* Label role */
    font-weight: 300;
    line-height: 1.5;
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    text-decoration: underline;
  }

  footer.chrome-band {
    text-align: left;
  }

  .footer-text {
    margin: 0;
    font-size: 14px; /* Label role */
    font-weight: 300;
    line-height: 1.5;
  }

  main {
    background-color: var(--color-dominant);
  }
</style>
