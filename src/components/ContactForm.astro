---
// Contact form island (CONT-01, CONT-02): a dependency-free vanilla-JS form,
// mirroring Lightbox.astro's pattern (typed <script>, no framework, no
// client:* directive). Submits via fetch() to Web3Forms (03-RESEARCH.md
// Pattern 2) with a client-side honeypot short-circuit that runs BEFORE the
// network call (03-RESEARCH.md Pattern 1, 03-UI-SPEC.md Layout Notes).
//
// Localized copy is computed once here (frontmatter), same as Lightbox's
// per-locale label strings — but since the <script> below cannot read Astro
// frontmatter consts directly, every string the script needs at runtime is
// passed through as a data-* attribute on the <form>, mirroring how
// Lightbox.astro passes slide data via data-src/data-alt on hidden <li>s.
//
// D-14/D-15 (04.1-03-PLAN.md): refactored onto the shared Input/Textarea/
// Button primitives. The per-field error <p data-role="error-*"> elements
// stay as sibling markup owned by this component (not inside Input/Textarea)
// since the <script> below sets their textContent imperatively at
// validation time — Input/Textarea's own `error` prop only supports a
// build-time-known string, not this component's runtime validation state.
import Input from './Input.astro';
import Textarea from './Textarea.astro';
import Button from './Button.astro';

interface Props {
  locale: 'fr' | 'en';
}

const { locale } = Astro.props;

const nameLabel = locale === 'en' ? 'Name' : 'Nom';
const emailLabel = locale === 'en' ? 'Email' : 'E-mail';
const messageLabel = locale === 'en' ? 'Message' : 'Message';
const honeypotLabel = locale === 'en' ? 'Leave this field empty' : 'Laissez ce champ vide';

const submitLabel = locale === 'en' ? 'Send message' : 'Envoyer le message';
const submittingLabel = locale === 'en' ? 'Sending…' : 'Envoi en cours…';

const successMessage =
  locale === 'en'
    ? "Thank you, your message has been sent. I'll get back to you soon."
    : 'Merci, votre message a bien été envoyé. Je vous répondrai bientôt.';

// Exact mailbox alias per 03-CONTEXT.md D-07 clarification / 01-CONTEXT.md D-14.
const submissionErrorMessage =
  locale === 'en'
    ? 'Something went wrong. Please try again, or email me directly at contact@atelierjacquelinesuzanne.fr.'
    : "Une erreur est survenue. Réessayez, ou écrivez-moi directement à contact@atelierjacquelinesuzanne.fr.";

const errNameBlank = locale === 'en' ? 'Please enter your name.' : 'Merci d’indiquer votre nom.';
const errEmailBlank = locale === 'en' ? 'Please enter your email.' : 'Merci d’indiquer votre e-mail.';
const errEmailInvalid =
  locale === 'en' ? 'Please enter a valid email address.' : 'Merci d’indiquer une adresse e-mail valide.';
const errMessageBlank = locale === 'en' ? 'Please enter a message.' : 'Merci d’indiquer votre message.';
---

<form
  id="contact-form"
  data-role="contact-form"
  data-submit-label={submitLabel}
  data-submitting-label={submittingLabel}
  data-success-message={successMessage}
  data-error-message={submissionErrorMessage}
  data-err-name-blank={errNameBlank}
  data-err-email-blank={errEmailBlank}
  data-err-email-invalid={errEmailInvalid}
  data-err-message-blank={errMessageBlank}
  class="contact-form"
  novalidate
>
  <div class="contact-form__field">
    <Input label={nameLabel} id="contact-name" type="text" name="name" required />
    <p data-role="error-name" class="contact-form__error" role="alert"></p>
  </div>

  <div class="contact-form__field">
    <Input label={emailLabel} id="contact-email" type="email" name="email" required />
    <p data-role="error-email" class="contact-form__error" role="alert"></p>
  </div>

  <div class="contact-form__field">
    <Textarea label={messageLabel} id="contact-message" name="message" required />
    <p data-role="error-message" class="contact-form__error" role="alert"></p>
  </div>

  {/* Honeypot (CONT-02, 03-UI-SPEC.md): decoy field for the `website`
      bot-autofill target, hidden via off-screen positioning (not
      display:none/visibility:hidden, which some bots specifically detect and
      skip filling) so it stays fillable by a script but invisible/unreachable
      to real visitors and assistive tech. */}
  <div class="contact-form__honeypot">
    <label for="contact-website">{honeypotLabel}</label>
    <input
      type="text"
      id="contact-website"
      name="website"
      data-role="honeypot"
      tabindex="-1"
      aria-hidden="true"
      autocomplete="off"
    />
  </div>

  <div class="contact-form__submit-wrap">
    <Button type="submit" data-role="submit-button" variant="primary">{submitLabel}</Button>
  </div>
</form>

<p data-role="form-status" class="contact-form__status" aria-live="polite"></p>

<script>
  import { isBlank, isHoneypotTriggered, isValidEmail } from '../lib/contact-form';

  const form = document.querySelector<HTMLFormElement>('#contact-form');
  const statusEl = document.querySelector<HTMLElement>('[data-role="form-status"]');

  if (form && statusEl) {
    const submitButton = form.querySelector<HTMLButtonElement>('[data-role="submit-button"]');
    const errorNameEl = form.querySelector<HTMLElement>('[data-role="error-name"]');
    const errorEmailEl = form.querySelector<HTMLElement>('[data-role="error-email"]');
    const errorMessageEl = form.querySelector<HTMLElement>('[data-role="error-message"]');

    const submitLabel = form.dataset.submitLabel ?? '';
    const submittingLabel = form.dataset.submittingLabel ?? '';
    const successMessage = form.dataset.successMessage ?? '';
    const errorMessage = form.dataset.errorMessage ?? '';
    const errNameBlank = form.dataset.errNameBlank ?? '';
    const errEmailBlank = form.dataset.errEmailBlank ?? '';
    const errEmailInvalid = form.dataset.errEmailInvalid ?? '';
    const errMessageBlank = form.dataset.errMessageBlank ?? '';

    function clearErrors() {
      if (errorNameEl) errorNameEl.textContent = '';
      if (errorEmailEl) errorEmailEl.textContent = '';
      if (errorMessageEl) errorMessageEl.textContent = '';
    }

    function renderSuccess() {
      statusEl!.textContent = successMessage;
      statusEl!.classList.remove('contact-form__status--error');
    }

    // D-03/Pitfall 2: no destructive-red token exists anymore — toggle a CSS
    // class (bold ink text) instead of setting an inline style.color that
    // would otherwise silently point at an undefined custom property.
    function renderSubmissionError() {
      statusEl!.textContent = errorMessage;
      statusEl!.classList.add('contact-form__status--error');
    }

    function setSubmitting(submitting: boolean) {
      if (!submitButton) return;
      submitButton.disabled = submitting;
      submitButton.style.opacity = submitting ? '0.6' : '';
      submitButton.style.cursor = submitting ? 'not-allowed' : '';
      submitButton.textContent = submitting ? submittingLabel : submitLabel;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusEl!.textContent = '';
      statusEl!.classList.remove('contact-form__status--error');
      clearErrors();

      const data = new FormData(form);
      const honeypot = String(data.get('website') ?? '');

      // Honeypot short-circuit MUST run before any network call (Pattern 1) —
      // never reveal the detection mechanism to whoever/whatever submitted it.
      if (isHoneypotTriggered(honeypot)) {
        renderSuccess();
        return;
      }

      const name = String(data.get('name') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();
      const message = String(data.get('message') ?? '').trim();

      let hasError = false;
      if (isBlank(name)) {
        if (errorNameEl) errorNameEl.textContent = errNameBlank;
        hasError = true;
      }
      if (isBlank(email)) {
        if (errorEmailEl) errorEmailEl.textContent = errEmailBlank;
        hasError = true;
      } else if (!isValidEmail(email)) {
        if (errorEmailEl) errorEmailEl.textContent = errEmailInvalid;
        hasError = true;
      }
      if (isBlank(message)) {
        if (errorMessageEl) errorMessageEl.textContent = errMessageBlank;
        hasError = true;
      }

      if (hasError) return;

      setSubmitting(true);
      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            access_key: import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY,
            name,
            email,
            message,
          }),
        });
        const json = await response.json();
        if (response.ok && json.success) {
          renderSuccess();
          form.reset();
        } else {
          renderSubmissionError();
        }
      } catch {
        renderSubmissionError();
      } finally {
        setSubmitting(false);
      }
    });
  }
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* D-03 ink-only error convention: thicker ink border on the field's
     Input/Textarea when its sibling error message is non-empty. :global()
     is required since Input.astro/Textarea.astro render their own
     `.field__input`/`.field__textarea` classes under their own component
     scope, not ContactForm's. */
  .contact-form__field:has(.contact-form__error:not(:empty)) :global(.field__input),
  .contact-form__field:has(.contact-form__error:not(:empty)) :global(.field__textarea) {
    border: var(--border-focus) solid var(--color-ink);
  }

  .contact-form__error {
    margin: 0;
    font-size: var(--text-label-size); /* Label role */
    font-weight: var(--weight-semibold);
    line-height: var(--text-label-leading);
    color: var(--color-ink);
    min-height: 1.5em;
  }

  .contact-form__honeypot {
    position: absolute;
    left: -9999px;
  }

  .contact-form__submit-wrap {
    align-self: flex-start;
  }

  .contact-form__status {
    margin: var(--space-xl) 0 0;
    font-size: var(--text-body-size); /* Body role */
    font-weight: var(--weight-regular);
    line-height: var(--text-body-leading);
    color: var(--color-ink);
  }

  /* D-03/Pitfall 2: submission-failure status is a class toggle, not an
     inline style.color pointing at a since-removed semantic error token. */
  .contact-form__status--error {
    font-weight: var(--weight-semibold);
  }
</style>
