---
// Full-size image lightbox (PORT-02, D-05/D-06): a dependency-free vanilla-JS
// island built on the native <dialog> element. `.showModal()` gives native
// focus containment + Escape-to-close for free (02-RESEARCH.md Pattern 3) —
// do NOT hand-roll a custom modal-focus-cycling handler or an Escape
// keydown listener here (02-RESEARCH.md Pitfall 1/Don't Hand-Roll).
// Everything else — prev/next, ArrowLeft/Right, touch swipe, the counter,
// preloading — is domain-specific and must be hand-written.
//
// Hook contract: any element on the page carrying `data-gallery-thumb` and a
// numeric `data-index` (0-based, matching this gallery's `images` array
// order) is treated as a trigger. Clicking it opens the lightbox at that
// index and stores the element as the return-focus target for when the
// dialog closes. See src/pages/galleries/[slug].astro and the EN
// counterpart for the trigger markup (Plan 03/04).
import { fullSizeUrl } from '../lib/image';
import type { GalleryImage } from '../lib/sanity';

interface Props {
  images: GalleryImage[];
  locale: 'fr' | 'en';
}

const { images, locale } = Astro.props;

const ariaLabel = locale === 'en' ? 'Image viewer' : 'Visionneuse d’image';
const closeLabel = locale === 'en' ? 'Close' : 'Fermer';
const prevLabel = locale === 'en' ? 'Previous image' : 'Image précédente';
const nextLabel = locale === 'en' ? 'Next image' : 'Image suivante';

// Full-size sources + localized alt, embedded as build-time data for the
// runtime script to read — the script never imports the build-time image
// module (src/lib/image.ts only runs in Astro frontmatter/Node, never in
// shipped client JS).
const slides = images.map((img) => ({
  src: fullSizeUrl(img, 2000),
  alt: img.alt?.[locale] ?? '',
  credit: img.rights?.displayCredit === false ? '' : img.rights?.credit ?? 'Romane Lepont',
  copyright: img.rights?.displayCredit === false
    ? ''
    : img.rights?.copyrightNotice ?? '© Romane Lepont — Tous droits réservés',
}));
---

<dialog id="lightbox" aria-label={ariaLabel}>
  <button type="button" class="lightbox__control lightbox__close" data-action="close" aria-label={closeLabel}>
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <button type="button" class="lightbox__control lightbox__prev" data-action="prev" aria-label={prevLabel}>
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button type="button" class="lightbox__control lightbox__next" data-action="next" aria-label={nextLabel}>
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
  <img data-role="lightbox-image" class="lightbox__image" alt="" />
  <p data-role="credit" class="lightbox__credit"></p>
  <p data-role="counter" class="lightbox__counter" aria-live="polite"></p>
</dialog>

{/* Build-time data for the runtime script to read: full-size src + localized
    alt per image, in gallery order (index == array position). Hidden list
    items (not a JSON <script> block) so Astro's HTML escaping handles any
    special characters in alt text safely, and the island never needs to
    parse embedded JSON. */}
<ul hidden data-role="lightbox-data">
  {slides.map((slide) => (
    <li data-src={slide.src} data-alt={slide.alt} data-credit={slide.credit} data-copyright={slide.copyright} />
  ))}
</ul>

<script>
  interface Slide {
    src: string;
    alt: string;
    credit: string;
    copyright: string;
  }

  const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
  const dataEl = document.querySelector<HTMLUListElement>('ul[data-role="lightbox-data"]');

  if (dialog && dataEl) {
    const slides: Slide[] = Array.from(dataEl.querySelectorAll<HTMLLIElement>('li')).map((li) => ({
      src: li.dataset.src ?? '',
      alt: li.dataset.alt ?? '',
      credit: li.dataset.credit ?? '',
      copyright: li.dataset.copyright ?? '',
    }));
    const imageEl = dialog.querySelector<HTMLImageElement>('[data-role="lightbox-image"]');
    const counterEl = dialog.querySelector<HTMLElement>('[data-role="counter"]');
    const creditEl = dialog.querySelector<HTMLElement>('[data-role="credit"]');
    const closeBtn = dialog.querySelector<HTMLButtonElement>('[data-action="close"]');
    const prevBtn = dialog.querySelector<HTMLButtonElement>('[data-action="prev"]');
    const nextBtn = dialog.querySelector<HTMLButtonElement>('[data-action="next"]');

    let current = 0;
    let trigger: HTMLElement | null = null;

    function preload(index: number) {
      if (index < 0 || index >= slides.length) return;
      const img = new Image();
      img.src = slides[index].src;
    }

    function render() {
      const slide = slides[current];
      if (!slide || !imageEl || !counterEl) return;
      imageEl.src = slide.src;
      imageEl.alt = slide.alt;
      counterEl.textContent = `${current + 1} / ${slides.length}`;
      if (creditEl) {
        creditEl.textContent = [slide.credit, slide.copyright].filter(Boolean).join(' · ');
        creditEl.hidden = !creditEl.textContent;
      }
      // Preload neighbours for perceived performance on prev/next.
      preload(current - 1);
      preload(current + 1);
    }

    function showPrev() {
      current = current === 0 ? slides.length - 1 : current - 1;
      render();
    }

    function showNext() {
      current = current === slides.length - 1 ? 0 : current + 1;
      render();
    }

    function open(index: number, triggerEl: HTMLElement) {
      current = index;
      trigger = triggerEl;
      render();
      // showModal() is what gives native focus containment + Escape-to-close
      // for free — do not hand-roll either (02-RESEARCH.md Pitfall 1).
      dialog!.showModal();
    }

    closeBtn?.addEventListener('click', () => dialog!.close());
    prevBtn?.addEventListener('click', showPrev);
    nextBtn?.addEventListener('click', showNext);

    // Arrow-key image navigation is domain-specific to the lightbox feature
    // — <dialog> only gives Escape for free, not this.
    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        showPrev();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        showNext();
      }
    });

    // Return focus to the triggering thumbnail on close (native <dialog>
    // does return focus to whatever had it before showModal(), but since we
    // want it explicitly on the recorded trigger element in all cases).
    dialog.addEventListener('close', () => {
      trigger?.focus();
    });

    // Touch swipe: 50px threshold, horizontal-dominance guard so a vertical
    // scroll gesture isn't misread as a swipe (02-RESEARCH.md Code Examples).
    const SWIPE_THRESHOLD_PX = 50;
    let touchStartX = 0;
    let touchStartY = 0;

    dialog.addEventListener(
      'touchstart',
      (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      },
      { passive: true },
    );

    dialog.addEventListener(
      'touchend',
      (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) > SWIPE_THRESHOLD_PX && Math.abs(dx) > Math.abs(dy)) {
          if (dx > 0) {
            showPrev();
          } else {
            showNext();
          }
        }
      },
      { passive: true },
    );

    // Bind every thumbnail on the page carrying the hook contract — see the
    // file-level comment above for the contract this island expects from
    // its host page.
    document.querySelectorAll<HTMLElement>('[data-gallery-thumb]').forEach((el) => {
      el.addEventListener('click', () => {
        const index = Number(el.dataset.index ?? '0');
        open(index, el);
      });
    });
  }
</script>

<style>
  dialog#lightbox {
    padding: 0;
    border: none;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    background: rgba(26, 26, 26, 0.96); /* Ink-equivalent scrim (var(--color-ink)) — documented exception, not var(--color-accent) */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  dialog#lightbox::backdrop {
    background: rgba(26, 26, 26, 0.96);
  }

  .lightbox__image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    display: block;
  }

  .lightbox__control {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px; /* WCAG 2.5.5 tap-target floor, via padding not icon size */
    min-height: 44px;
    padding: var(--space-sm, 8px);
    background: transparent;
    border: none;
    color: var(--color-dominant);
    cursor: pointer;
  }

  .lightbox__control:focus-visible {
    outline: 2px solid var(--color-dominant);
    outline-offset: 2px;
  }

  .lightbox__close {
    top: var(--space-md, 16px);
    right: var(--space-md, 16px);
  }

  .lightbox__prev {
    left: var(--space-md, 16px);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox__next {
    right: var(--space-md, 16px);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox__counter {
    position: absolute;
    bottom: var(--space-md, 16px);
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    font-size: 14px; /* Label role */
    font-weight: var(--weight-regular);
    color: var(--color-dominant);
  }

  .lightbox__credit {
    position: absolute;
    right: var(--space-md, 16px);
    bottom: var(--space-md, 16px);
    max-width: min(60vw, 640px);
    margin: 0;
    color: var(--color-dominant);
    font-size: 12px;
    line-height: 1.4;
    text-align: right;
  }

  @media (max-width: 600px) {
    .lightbox__credit {
      right: var(--space-sm, 8px);
      bottom: 48px;
      left: var(--space-sm, 8px);
      max-width: none;
      text-align: center;
    }
  }
</style>
