---
// Full-size image lightbox (PORT-02, D-05/D-06): a dependency-free vanilla-JS
// island built on the native <dialog> element. `.showModal()` gives native
// focus containment + Escape-to-close for free (02-RESEARCH.md Pattern 3) —
// do NOT hand-roll a custom modal-focus-cycling handler or an Escape
// keydown listener here (02-RESEARCH.md Pitfall 1/Don't Hand-Roll).
// Everything else — prev/next, ArrowLeft/Right, touch swipe, the counter,
// preloading — is domain-specific and must be hand-written.
//
// Hook contract: any element on the page carrying `data-gallery-thumb` and a
// numeric `data-index` (0-based, matching this gallery's `images` array
// order) is treated as a trigger. Clicking it opens the lightbox at that
// index and stores the element as the return-focus target for when the
// dialog closes. See src/pages/galleries/[slug].astro and the EN
// counterpart for the trigger markup (Plan 03/04).
import { fullSizeUrl, responsiveImageSrcSet } from '../lib/image';
import type { GalleryImage } from '../lib/sanity';

interface Props {
  images: GalleryImage[];
  locale: 'fr' | 'en';
}

const { images, locale } = Astro.props;

const ariaLabel = locale === 'en' ? 'Image viewer' : 'Visionneuse d’image';
const closeLabel = locale === 'en' ? 'Close' : 'Fermer';
const prevLabel = locale === 'en' ? 'Previous image' : 'Image précédente';
const nextLabel = locale === 'en' ? 'Next image' : 'Image suivante';

// Full-size sources + localized alt, embedded as build-time data for the
// runtime script to read — the script never imports the build-time image
// module (src/lib/image.ts only runs in Astro frontmatter/Node, never in
// shipped client JS).
const slides = images.map((img) => ({
  src: fullSizeUrl(img, 2000),
  srcset: responsiveImageSrcSet(img, [640, 960, 1440, 2000]),
  alt: img.alt?.[locale] ?? '',
  credit: img.rights?.displayCredit === false ? '' : img.rights?.credit ?? 'Romane Lepont',
  copyright: img.rights?.displayCredit === false
    ? ''
    : img.rights?.copyrightNotice ?? '© Romane Lepont — Tous droits réservés',
}));
---

<dialog id="lightbox" aria-label={ariaLabel}>
  <button type="button" class="lightbox__control lightbox__close" data-action="close" aria-label={closeLabel}>
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <button type="button" class="lightbox__control lightbox__prev" data-action="prev" aria-label={prevLabel}>
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button type="button" class="lightbox__control lightbox__next" data-action="next" aria-label={nextLabel}>
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
  <img data-role="lightbox-image" class="lightbox__image" alt="" sizes="100vw" />
  <p data-role="credit" class="lightbox__credit"></p>
  <p data-role="counter" class="lightbox__counter" aria-live="polite"></p>
</dialog>

{/* Build-time data for the runtime script to read: full-size src + localized
    alt per image, in gallery order (index == array position). Hidden list
    items (not a JSON <script> block) so Astro's HTML escaping handles any
    special characters in alt text safely, and the island never needs to
    parse embedded JSON. */}
<ul hidden data-role="lightbox-data">
  {slides.map((slide) => (
    <li data-src={slide.src} data-srcset={slide.srcset} data-alt={slide.alt} data-credit={slide.credit} data-copyright={slide.copyright} />
  ))}
</ul>

<script>
  interface Slide {
    src: string;
    srcset: string;
    alt: string;
    credit: string;
    copyright: string;
  }

  const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
  const dataEl = document.querySelector<HTMLUListElement>('ul[data-role="lightbox-data"]');

  // Narrow local typing for the View Transitions DOM API (mirrors
  // HomeCarousel.astro's VTDocument convention) — avoids depending on
  // lib.dom's (not-yet-universal) ViewTransition types just to
  // feature-detect and call it.
  type VTDocument = Document & {
    startViewTransition?: (cb: () => void) => {
      finished: Promise<void>;
      ready: Promise<void>;
      updateCallbackDone: Promise<void>;
    };
  };
  const vtDoc = document as VTDocument;
  const MORPH_NAME = 'lightbox-morph';

  if (dialog && dataEl) {
    const slides: Slide[] = Array.from(dataEl.querySelectorAll<HTMLLIElement>('li')).map((li) => ({
      src: li.dataset.src ?? '',
      srcset: li.dataset.srcset ?? '',
      alt: li.dataset.alt ?? '',
      credit: li.dataset.credit ?? '',
      copyright: li.dataset.copyright ?? '',
    }));
    const imageEl = dialog.querySelector<HTMLImageElement>('[data-role="lightbox-image"]');
    const counterEl = dialog.querySelector<HTMLElement>('[data-role="counter"]');
    const creditEl = dialog.querySelector<HTMLElement>('[data-role="credit"]');
    const closeBtn = dialog.querySelector<HTMLButtonElement>('[data-action="close"]');
    const prevBtn = dialog.querySelector<HTMLButtonElement>('[data-action="prev"]');
    const nextBtn = dialog.querySelector<HTMLButtonElement>('[data-action="next"]');

    let current = 0;
    let trigger: HTMLElement | null = null;

    function preload(index: number) {
      if (index < 0 || index >= slides.length) return;
      const img = new Image();
      img.srcset = slides[index].srcset;
      img.sizes = '100vw';
      img.src = slides[index].src;
    }

    function render() {
      const slide = slides[current];
      if (!slide || !imageEl || !counterEl) return;
      imageEl.srcset = slide.srcset;
      imageEl.sizes = '100vw';
      imageEl.src = slide.src;
      imageEl.alt = slide.alt;
      counterEl.textContent = `${current + 1} / ${slides.length}`;
      if (creditEl) {
        creditEl.textContent = [slide.credit, slide.copyright].filter(Boolean).join(' · ');
        creditEl.hidden = !creditEl.textContent;
      }
      // Preload neighbours for perceived performance on prev/next.
      preload(current - 1);
      preload(current + 1);
    }

    function showPrev() {
      current = current === 0 ? slides.length - 1 : current - 1;
      render();
    }

    function showNext() {
      current = current === slides.length - 1 ? 0 : current + 1;
      render();
    }

    function open(index: number, triggerEl: HTMLElement) {
      current = index;
      trigger = triggerEl;

      // Click-to-expand View Transitions morph (sketch 004 variant A2): the
      // clicked thumbnail grows smoothly into the Lightbox image instead of
      // an abrupt swap. Purely additive — if startViewTransition isn't
      // supported, doOpen() runs directly and every existing behavior is
      // byte-for-byte unchanged.
      const thumbImg = triggerEl.querySelector<HTMLImageElement>('img');

      const doOpen = () => {
        if (thumbImg) thumbImg.style.viewTransitionName = '';
        render();
        // showModal() is what gives native focus containment + Escape-to-close
        // for free — do not hand-roll either (02-RESEARCH.md Pitfall 1).
        dialog!.showModal();
        if (imageEl) imageEl.style.viewTransitionName = MORPH_NAME;
      };

      if (thumbImg && typeof vtDoc.startViewTransition === 'function') {
        // Name the OLD element (clicked thumbnail) FIRST so the old snapshot
        // captures it; doOpen() then hands the name to the Lightbox image so
        // the new snapshot captures the enlarged view.
        thumbImg.style.viewTransitionName = MORPH_NAME;
        vtDoc.startViewTransition(doOpen);
      } else {
        doOpen();
      }
    }

    // All close paths (button, Escape, backdrop) funnel through this helper
    // so the closing morph is consistent everywhere.
    function closeWithMorph() {
      const thumbImg = trigger?.querySelector<HTMLImageElement>('img');

      const doClose = () => {
        if (imageEl) imageEl.style.viewTransitionName = '';
        if (thumbImg) thumbImg.style.viewTransitionName = MORPH_NAME;
        dialog!.close();
      };

      if (thumbImg && typeof vtDoc.startViewTransition === 'function') {
        // Ensure the OLD snapshot (open Lightbox image) still carries the
        // name — open() already set it, but this is a defensive guarantee.
        if (imageEl) imageEl.style.viewTransitionName = MORPH_NAME;
        const transition = vtDoc.startViewTransition(doClose);
        transition.finished.then(
          () => {
            if (thumbImg) thumbImg.style.viewTransitionName = '';
          },
          () => {
            if (thumbImg) thumbImg.style.viewTransitionName = '';
          },
        );
      } else {
        doClose();
      }
    }

    closeBtn?.addEventListener('click', () => closeWithMorph());
    prevBtn?.addEventListener('click', showPrev);
    nextBtn?.addEventListener('click', showNext);

    // The native `cancel` event fires on Escape and is cancelable —
    // preventing it stops <dialog>'s native close so the morph can run
    // dialog.close() itself inside closeWithMorph().
    dialog.addEventListener('cancel', (e) => {
      e.preventDefault();
      closeWithMorph();
    });

    // Backdrop click: only a click on the dialog's own backdrop area (not
    // the image or control buttons, whose clicks target descendants) closes
    // it — matches the sketch modal's backdrop-close.
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeWithMorph();
    });

    // Arrow-key image navigation is domain-specific to the lightbox feature
    // — <dialog> only gives Escape for free, not this.
    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        showPrev();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        showNext();
      }
    });

    // Return focus to the triggering thumbnail on close (native <dialog>
    // does return focus to whatever had it before showModal(), but since we
    // want it explicitly on the recorded trigger element in all cases).
    dialog.addEventListener('close', () => {
      trigger?.focus();
    });

    // Touch swipe: 50px threshold, horizontal-dominance guard so a vertical
    // scroll gesture isn't misread as a swipe (02-RESEARCH.md Code Examples).
    const SWIPE_THRESHOLD_PX = 50;
    let touchStartX = 0;
    let touchStartY = 0;

    dialog.addEventListener(
      'touchstart',
      (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      },
      { passive: true },
    );

    dialog.addEventListener(
      'touchend',
      (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) > SWIPE_THRESHOLD_PX && Math.abs(dx) > Math.abs(dy)) {
          if (dx > 0) {
            showPrev();
          } else {
            showNext();
          }
        }
      },
      { passive: true },
    );

    // Bind every thumbnail on the page carrying the hook contract — see the
    // file-level comment above for the contract this island expects from
    // its host page.
    document.querySelectorAll<HTMLElement>('[data-gallery-thumb]').forEach((el) => {
      el.addEventListener('click', () => {
        const index = Number(el.dataset.index ?? '0');
        open(index, el);
      });
    });
  }
</script>

<style>
  dialog#lightbox {
    padding: 0;
    border: none;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    background: rgba(26, 26, 26, 0.96); /* Ink-equivalent scrim (var(--color-ink)) — documented exception, not var(--color-accent) */
  }

  /* Bug fix (lightbox-dialog-always-visible): `display` must only be `flex`
     while the dialog is open. An unconditional `display: flex` on the bare
     `dialog#lightbox` selector is author-origin CSS, which always wins over
     the UA stylesheet's `dialog:not([open]) { display: none; }` rule
     regardless of specificity — that made the closed dialog render as
     ordinary 100vw x 100vh page content below the footer. The explicit
     `:not([open])` rule below is a defensive backstop so this can never
     regress even if a browser's UA-stylesheet default ever changes. */
  dialog#lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  dialog#lightbox:not([open]) {
    display: none;
  }

  dialog#lightbox::backdrop {
    background: rgba(26, 26, 26, 0.96);
  }

  .lightbox__image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    display: block;
  }

  .lightbox__control {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px; /* WCAG 2.5.5 tap-target floor, via padding not icon size */
    min-height: 44px;
    padding: var(--space-sm, 8px);
    background: transparent;
    border: none;
    color: var(--color-dominant);
    cursor: pointer;
  }

  .lightbox__control:focus-visible {
    outline: 2px solid var(--color-dominant);
    outline-offset: 2px;
  }

  .lightbox__close {
    top: var(--space-md, 16px);
    right: var(--space-md, 16px);
  }

  .lightbox__prev {
    left: var(--space-md, 16px);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox__next {
    right: var(--space-md, 16px);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox__counter {
    position: absolute;
    bottom: var(--space-md, 16px);
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    font-size: 14px; /* Label role */
    font-weight: var(--weight-regular);
    color: var(--color-dominant);
  }

  .lightbox__credit {
    position: absolute;
    right: var(--space-md, 16px);
    bottom: var(--space-md, 16px);
    max-width: min(60vw, 640px);
    margin: 0;
    color: var(--color-dominant);
    font-size: 12px;
    line-height: 1.4;
    text-align: right;
  }

  @media (max-width: 600px) {
    .lightbox__credit {
      right: var(--space-sm, 8px);
      bottom: 48px;
      left: var(--space-sm, 8px);
      max-width: none;
      text-align: center;
    }
  }
</style>

<style is:global>
  /* View Transitions pseudo-elements for the click-to-expand morph (sketch
     004 variant A2) live on the document root, outside this component's
     subtree — Astro's scoped <style> above cannot target
     ::view-transition-*, so this must be a global block (mirrors
     HomeCarousel.astro's precedent for the same reason). */
  ::view-transition-group(lightbox-morph),
  ::view-transition-old(lightbox-morph),
  ::view-transition-new(lightbox-morph) {
    animation-duration: 400ms;
    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* The View Transitions API does not honor prefers-reduced-motion on its
     own — this override is a hard requirement, not optional polish. */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-group(*),
    ::view-transition-old(*),
    ::view-transition-new(*) {
      animation: none !important;
    }
  }
</style>
