    .home-hero__wordmark {
      font-size: 48px;
    }

    /* Grid hero-tile wordmark — mobile-width override (Typography table). */
    .home-grid__wordmark {
      font-size: 16px;
    }

    .home-grid__tiles {
      grid-template-columns: 1fr;
    }
  }
