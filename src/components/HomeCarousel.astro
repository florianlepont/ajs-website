---
// Homepage hero carousel + 2-column grid toggle (D-08/D-09/D-10/D-12), the
// real gallery entry point replacing Phase 1's placeholder homepage. A
// dependency-free vanilla-JS island (no client:* directive — no framework to
// hydrate), mirroring Lightbox.astro's hidden-data-node + typed <script>
// pattern (04.1-RESEARCH.md Pattern 4).
//
// T-04.1-04-ID (threat model, mitigate): gallery data below is pre-fetched
// and pre-filtered (D-12) by the calling page's frontmatter via
// getGalleries() — this component and its client <script> never import
// src/lib/sanity.ts, so SANITY_API_READ_TOKEN never reaches the browser.
//
// This component also renders the homepage's own <header> (nav +
// carousel/grid toggle + LanguageSwitcher) since the page invokes
// `<BaseLayout headerVariant="none">` to avoid a duplicate <header> — see
// 04.1-UI-SPEC.md Layout Notes ("Homepage — Carousel mode" / "Grid mode").
import { getRelativeLocaleUrl } from 'astro:i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface GalleryEntry {
  slug: string;
  title: string;
  heroSrc: string;
  gridSrc: string;
  alt: string;
}

interface Props {
  locale: 'fr' | 'en';
  galleries: GalleryEntry[];
}

const { locale, galleries } = Astro.props;
const isEn = locale === 'en';

// Copy verbatim from the prototype (UI-SPEC Copywriting Contract) — hardcoded
// per the "Homepage intro copy source" decision, not sourced from
// siteSettings.welcomeHeading/welcomeBody.
// homeHref is still needed below for the logo's own link — no separate
// "Accueil"/"Home" nav link anymore (direct user feedback: redundant,
// since clicking the logo already goes home).
const homeHref = getRelativeLocaleUrl(locale, '');
// Matches BaseLayout.astro's aboutLabel/contactLabel/aboutHref/contactHref
// exactly — the homepage's own header renders its own nav (headerVariant
//="none" suppresses BaseLayout's), but must still surface every primary
// site section, not just Home/Galleries (real user feedback: About/Contact
// were reported missing from the homepage nav).
const aboutLabel = isEn ? 'About' : 'À propos';
const aboutHref = getRelativeLocaleUrl(locale, 'about');
const contactLabel = 'Contact';
const contactHref = getRelativeLocaleUrl(locale, 'contact');
const toggleCarouselLabel = isEn ? 'Carousel' : 'Carrousel';
const toggleGridLabel = isEn ? 'Grid' : 'Grille';
const wordmark = 'Atelier Jacqueline Suzanne';
const introBody = isEn
  ? "This site showcases Romane Lepont's photographic work and lets you buy a piece directly online."
  : "Le site présente le travail photographique de Romane Lepont et permet l'achat d'une œuvre directement en ligne.";
const byline = isEn ? 'A project by Romane Lepont' : 'Un projet de Romane Lepont';

const totalLabel = String(galleries.length).padStart(2, '0');
const firstGallery = galleries[0];

// Base-aware logo paths (matches BaseLayout.astro's assetBase pattern) — a
// bare root-relative "/logos/..." src 404s under the GitHub Pages deploy's
// ASTRO_BASE=/ajs-website/ subpath (.github/workflows/deploy.yml), even
// though every <a href> here is already base-safe via getRelativeLocaleUrl.
const assetBase = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const logoWhiteSrc = `${assetBase}/logos/AJS_Brutalist_White_Transparent.png`;
const logoBlackSrc = `${assetBase}/logos/AJS_Brutalist_Black_Transparent.png`;
---

{galleries.length === 0 ? (
  <p class="home-empty">{isEn ? 'No galleries available yet.' : 'Aucune galerie disponible pour le moment.'}</p>
) : (
  <section
    class="home"
    data-display-mode="carousel"
    style={{ '--wordmark-photo': `url(${firstGallery.heroSrc})` }}
  >
    <header class="home-header" data-role="home-header">
      <a href={homeHref} class="home-logo" aria-label={wordmark}>
        <span class="home-logo__chip" aria-hidden="true"></span>
        <img src={logoBlackSrc} alt="" class="home-logo__img home-logo__img--default" />
        <img src={logoWhiteSrc} alt="" class="home-logo__img home-logo__img--hover" />
      </a>
      <nav class="home-nav" aria-label="Primary">
        <a href={aboutHref} class="home-nav-link">{aboutLabel}</a>
        <a href={contactHref} class="home-nav-link">{contactLabel}</a>
      </nav>
      <button
        type="button"
        class="home-toggle"
        data-role="mode-toggle"
        data-action="toggle-mode"
        data-label-carousel={toggleCarouselLabel}
        data-label-grid={toggleGridLabel}
        aria-label={toggleGridLabel}
      >
        <span aria-hidden="true" class="home-toggle__morph">
          <span class="home-toggle__morph-cell"></span>
          <span class="home-toggle__morph-cell"></span>
          <span class="home-toggle__morph-cell"></span>
          <span class="home-toggle__morph-cell"></span>
          <span class="home-toggle__morph-cell"></span>
          <span class="home-toggle__morph-cell"></span>
        </span>
      </button>
      <LanguageSwitcher />
    </header>

    <div class="home-hero" data-role="home-carousel">
      {/* Wraps the photo + its overlaid chrome (scrim, arrows, caption) in
          its own sized box, separate from .home-hero__accent below. On
          mobile, .home-hero__accent is in-flow (not absolute — see its
          mobile override), which used to make .home-hero itself grow taller
          than the photo to fit the panel; since .home-hero__img/__caption
          were absolutely positioned against .home-hero's *entire* (grown)
          box, the photo silently stretched down behind the panel and the
          caption landed past it, overlapping. This wrapper is what
          .home-hero__img/__scrim/__arrow/__caption are now absolutely
          positioned against, so they stay confined to the photo's own
          16:9 band regardless of how tall the accent panel makes
          .home-hero grow. */}
      <div class="home-hero__photo">
        <img data-role="hero-image" src={firstGallery.heroSrc} alt={firstGallery.alt} class="home-hero__img" />
        <div class="home-hero__scrim" aria-hidden="true"></div>

        <div class="home-hero__caption">
          {/* Direct request: replaces the prev/next arrow buttons with a
              clickable dashed progress indicator (one segment per gallery,
              current one highlighted) — navigation itself moves to keyboard
              arrow keys and touch swipe, handled in the <script> below. Each
              dash is still a real, individually-focusable/clickable <button>
              (not decorative), so mouse/touch users who don't know the
              keyboard shortcut retain a direct way to jump to any gallery.
              Nested inside .home-hero__caption (bottom-left, not the top)
              per direct follow-up feedback, so it flows naturally above the
              index/title/byline instead of needing its own hardcoded
              vertical offset — one less pixel-math dependency to keep in
              sync with the rest of the caption's content. */}
          <div class="home-hero__progress" data-role="progress" role="tablist" aria-label={isEn ? 'Choose a gallery' : 'Choisir une galerie'}>
            {galleries.map((gallery, i) => (
              <button
                type="button"
                class="home-hero__progress-dash"
                data-action="go-to"
                data-index={i}
                role="tab"
                aria-current={i === 0 ? 'true' : 'false'}
                aria-label={`${gallery.title} (${i + 1}/${galleries.length})`}
              />
            ))}
          </div>
          <p class="home-hero__index" data-role="index-label">01 / {totalLabel}</p>
          <a class="home-hero__title" data-role="gallery-title" href={getRelativeLocaleUrl(locale, `galleries/${firstGallery.slug}`)}>{firstGallery.title.toUpperCase()}</a>
          <p class="home-hero__byline">{byline}</p>
        </div>
      </div>

      <div class="home-hero__accent" data-role="accent-panel" style={{ color: 'var(--color-on-accent)' }}>
        {/* D-08: --wordmark-photo is server-rendered on the .home section
            (above) from firstGallery.heroSrc, so the transparent cutout text
            reveals a photo immediately, before and without JS; render() keeps
            it synced with heroImg.src on every prev/next/auto-advance tick. */}
        <p class="home-hero__wordmark">Atelier<br />Jacqueline<br />Suzanne</p>
        <p class="home-hero__intro">{introBody}</p>
      </div>
    </div>

    <div class="home-grid" data-role="home-grid" hidden>
      <div class="home-grid__tiles">
        {/* D-06: non-link hero tile — same square sizing as every gallery
            tile, but a plain <div> (no gallery to navigate to). D-05: solid
            accent background, no photo/cutout. */}
        <div class="home-grid__tile home-grid__tile--hero">
          <p class="home-grid__wordmark">Atelier<br />Jacqueline<br />Suzanne</p>
          <p class="home-grid__intro-body">{introBody}</p>
        </div>
        {galleries.map((gallery) => (
          <a href={getRelativeLocaleUrl(locale, `galleries/${gallery.slug}`)} class="home-grid__tile">
            <img
              src={gallery.gridSrc}
              width="600"
              height="600"
              alt={gallery.alt}
              loading="lazy"
              decoding="async"
              class="home-grid__tile-img"
            />
            <div class="home-grid__tile-scrim" aria-hidden="true"></div>
            <span class="home-grid__tile-title">{gallery.title}</span>
          </a>
        ))}
      </div>
    </div>

    {/* Build-time data for the runtime script to read (Lightbox.astro
        precedent) — the script never imports src/lib/sanity, it only reads
        this already-fetched, already-filtered (D-12) static markup. */}
    <ul hidden data-role="home-carousel-data">
      {galleries.map((gallery) => (
        <li
          data-title={gallery.title}
          data-hero-src={gallery.heroSrc}
          data-alt={gallery.alt}
          data-href={getRelativeLocaleUrl(locale, `galleries/${gallery.slug}`)}
        />
      ))}
    </ul>

    <script>
      interface GalleryEntry {
        title: string;
        heroSrc: string;
        alt: string;
        href: string;
      }

      const root = document.querySelector<HTMLElement>('.home[data-display-mode]');
      const hero = document.querySelector<HTMLElement>('[data-role="home-carousel"]');
      const grid = document.querySelector<HTMLElement>('[data-role="home-grid"]');
      const dataEl = document.querySelector<HTMLUListElement>('ul[data-role="home-carousel-data"]');

      if (root && hero && grid && dataEl) {
        const galleries: GalleryEntry[] = Array.from(dataEl.querySelectorAll('li')).map((li) => ({
          title: li.dataset.title ?? '',
          heroSrc: li.dataset.heroSrc ?? '',
          alt: li.dataset.alt ?? '',
          href: li.dataset.href ?? '',
        }));

        // ACCENTS cycles generically via index % ACCENTS.length (RESEARCH.md
        // Open Question 3) — written for N galleries, not hardcoded to 2,
        // so it extends correctly once more galleries migrate. bg/text pairs
        // per the prototype's ACCENTS array (plan interfaces block).
        const ACCENTS: Array<{ bg: string; text: string }> = [
          { bg: 'var(--color-accent)', text: 'var(--color-on-accent)' },
          { bg: 'var(--palette-purple)', text: '#FFFFFF' },
          { bg: 'var(--palette-teal)', text: 'var(--color-ink)' },
          { bg: 'var(--palette-lime)', text: 'var(--color-ink)' },
          { bg: 'var(--palette-plum)', text: '#FFFFFF' },
        ];

        const heroImg = hero.querySelector<HTMLImageElement>('[data-role="hero-image"]');
        const indexLabel = hero.querySelector<HTMLElement>('[data-role="index-label"]');
        const titleEl = hero.querySelector<HTMLElement>('[data-role="gallery-title"]');
        const accentPanel = hero.querySelector<HTMLElement>('[data-role="accent-panel"]');
        const wordmarkEl = hero.querySelector<HTMLElement>('.home-hero__wordmark');
        const progressDashes = Array.from(hero.querySelectorAll<HTMLButtonElement>('[data-role="progress"] .home-hero__progress-dash'));

        let carouselIndex = 0;
        let timer: ReturnType<typeof setInterval> | null = null;

        // .home-hero__img uses the default object-position (50% 50%,
        // dead center) — kept as named constants so the crop math below
        // stays generic if that ever changes again.
        const OBJECT_POSITION_X = 0.5;
        const OBJECT_POSITION_Y = 0.5;

        // Direct user feedback: background-size:cover scoped to the small
        // wordmark box (the previous approach) shows an independently
        // re-cropped/zoomed slice of the photo, not the SAME slice that's
        // actually behind the panel — it doesn't read as a true cutout.
        // This computes the exact background-size/position the wordmark's
        // own background-image needs so it lines up pixel-for-pixel with
        // heroImg's own object-fit:cover crop — i.e. what you'd see if the
        // panel really were a hole cut in the same physical photo. Must be
        // computed in JS: CSS has no way to say "background-size:cover
        // relative to a DIFFERENT (larger) box than the element's own".
        function syncWordmarkAlignment() {
          if (!heroImg || !wordmarkEl) return;
          const naturalW = heroImg.naturalWidth;
          const naturalH = heroImg.naturalHeight;
          if (!naturalW || !naturalH) return;
          // Deliberately heroImg's own rect, not .home-hero's — heroImg now
          // has `inset: -6%` (the zoom fix above), so its actual rendered
          // box is already bigger than the visible hero container. Reading
          // it directly here means the crop math below automatically
          // reflects that expansion with no separate ZOOM_INSET_PCT term
          // needed — it's already baked into this rect.
          const heroRect = heroImg.getBoundingClientRect();
          const wordmarkRect = wordmarkEl.getBoundingClientRect();
          if (heroRect.width === 0 || heroRect.height === 0) return;
          // Same formula object-fit:cover itself uses: scale to fill,
          // cropping whichever axis overflows.
          const scale = Math.max(heroRect.width / naturalW, heroRect.height / naturalH);
          const renderedW = naturalW * scale;
          const renderedH = naturalH * scale;
          // How much of the scaled image is cropped off each edge — must
          // track heroImg's own object-position (OBJECT_POSITION_X/Y
          // above), not assume the 50%/50% (dead center) default.
          const cropX = (renderedW - heroRect.width) * OBJECT_POSITION_X;
          const cropY = (renderedH - heroRect.height) * OBJECT_POSITION_Y;
          // Where the wordmark box sits relative to the hero photo's own
          // top-left — both rects read via getBoundingClientRect() in the
          // same tick, so any scroll offset cancels out in the subtraction.
          const offsetX = wordmarkRect.left - heroRect.left;
          const offsetY = wordmarkRect.top - heroRect.top;
          wordmarkEl.style.setProperty('--wordmark-bg-size', `${renderedW}px ${renderedH}px`);
          wordmarkEl.style.setProperty(
            '--wordmark-bg-position',
            `${-(cropX + offsetX)}px ${-(cropY + offsetY)}px`,
          );
        }

        function render() {
          const gallery = galleries[carouselIndex];
          if (!gallery) return;
          const accent = ACCENTS[carouselIndex % ACCENTS.length];
          if (heroImg) {
            heroImg.src = gallery.heroSrc;
            heroImg.alt = gallery.alt;
            if (heroImg.complete) {
              syncWordmarkAlignment();
            } else {
              heroImg.addEventListener('load', syncWordmarkAlignment, { once: true });
            }
          }
          if (indexLabel) {
            indexLabel.textContent = `${String(carouselIndex + 1).padStart(2, '0')} / ${String(galleries.length).padStart(2, '0')}`;
          }
          if (titleEl) {
            titleEl.textContent = gallery.title.toUpperCase();
            titleEl.setAttribute('href', gallery.href);
          }
          if (accentPanel) {
            accentPanel.style.color = accent.text;
          }
          root!.style.setProperty('--current-accent', accent.bg);
          // D-08/D-09: keep the wordmark's photo-cutout background in sync
          // with the visible hero photo on every prev/next/auto-advance
          // tick, so the letters always reveal the currently-shown gallery.
          root!.style.setProperty('--wordmark-photo', `url(${gallery.heroSrc})`);
          progressDashes.forEach((dash, i) => {
            dash.setAttribute('aria-current', i === carouselIndex ? 'true' : 'false');
          });
        }

        function stopAutoAdvance() {
          if (timer) clearInterval(timer);
          timer = null;
        }

        // D-09: auto-advance every 6000ms, paused on hover/focus, resumed on
        // mouseleave/focusout — never paused permanently.
        function startAutoAdvance() {
          stopAutoAdvance();
          timer = setInterval(() => {
            carouselIndex = (carouselIndex + 1) % galleries.length;
            render();
          }, 6000);
        }

        function showCarousel() {
          root!.dataset.displayMode = 'carousel';
          hero!.hidden = false;
          grid!.hidden = true;
          startAutoAdvance();
        }

        function showGrid() {
          root!.dataset.displayMode = 'grid';
          hero!.hidden = true;
          grid!.hidden = false;
          stopAutoAdvance();
        }

        hero.addEventListener('mouseenter', stopAutoAdvance);
        hero.addEventListener('mouseleave', startAutoAdvance);
        hero.addEventListener('focusin', stopAutoAdvance);
        hero.addEventListener('focusout', startAutoAdvance);

        function goToPrev() {
          carouselIndex = (carouselIndex - 1 + galleries.length) % galleries.length;
          render();
        }

        function goToNext() {
          carouselIndex = (carouselIndex + 1) % galleries.length;
          render();
        }

        function goToIndex(i: number) {
          if (i < 0 || i >= galleries.length || i === carouselIndex) return;
          carouselIndex = i;
          render();
        }

        progressDashes.forEach((dash) => {
          dash.addEventListener('click', () => {
            const i = Number(dash.dataset.index);
            if (!Number.isNaN(i)) goToIndex(i);
          });
        });

        // Direct request: arrow-key navigation, only while the carousel
        // (not the grid) is showing, and only when focus isn't inside a
        // form control elsewhere on the page (About/Contact share this
        // layout's header, and a stray ArrowLeft/ArrowRight while typing
        // in an <input> shouldn't hijack the carousel).
        document.addEventListener('keydown', (event) => {
          if (root!.dataset.displayMode !== 'carousel') return;
          const target = event.target as HTMLElement | null;
          if (target && /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName)) return;
          if (event.key === 'ArrowLeft') {
            event.preventDefault();
            goToPrev();
          } else if (event.key === 'ArrowRight') {
            event.preventDefault();
            goToNext();
          }
        });

        // Direct request: swipe support on mobile. touchstart/touchend
        // (not touchmove) — only the net horizontal distance matters, and
        // this avoids fighting the browser's own vertical scroll handling
        // mid-gesture. Horizontal delta must clearly exceed vertical delta
        // (SWIPE_DIRECTION_RATIO) before it's treated as a swipe, so an
        // intentional vertical scroll over the hero never triggers a
        // gallery change.
        const SWIPE_MIN_DISTANCE = 50;
        const SWIPE_DIRECTION_RATIO = 1.5;
        let touchStartX = 0;
        let touchStartY = 0;
        const heroPhoto = hero.querySelector<HTMLElement>('.home-hero__photo');
        heroPhoto?.addEventListener('touchstart', (event) => {
          const touch = event.changedTouches[0];
          if (!touch) return;
          touchStartX = touch.clientX;
          touchStartY = touch.clientY;
        }, { passive: true });
        heroPhoto?.addEventListener('touchend', (event) => {
          const touch = event.changedTouches[0];
          if (!touch) return;
          const deltaX = touch.clientX - touchStartX;
          const deltaY = touch.clientY - touchStartY;
          if (Math.abs(deltaX) < SWIPE_MIN_DISTANCE) return;
          if (Math.abs(deltaX) < Math.abs(deltaY) * SWIPE_DIRECTION_RATIO) return;
          if (deltaX < 0) {
            goToNext();
          } else {
            goToPrev();
          }
        }, { passive: true });

        // D-01/D-02/D-03: a single stateful button — its aria-label always
        // names the mode you'd switch TO, read off its own data-label-*
        // attributes (the plain module script can't read frontmatter vars).
        const modeToggleBtn = root.querySelector<HTMLButtonElement>('[data-role="mode-toggle"]');

        // Shared-element morph target: the grid gallery tiles (hero tile
        // excluded — it has no matching carousel slide), queried once
        // alongside the other element lookups above. gridGalleryTiles[i]
        // corresponds 1:1 with galleries[i]/carouselIndex, since both derive
        // from the same server-rendered gallery order.
        const gridGalleryTiles = Array.from(
          grid.querySelectorAll<HTMLElement>('.home-grid__tile:not(.home-grid__tile--hero)'),
        );
        let namedMorphTile: HTMLElement | null = null;

        // Narrow local typing for the View Transitions DOM API — avoids
        // depending on lib.dom's (not-yet-universal) ViewTransition types
        // just to feature-detect and call it.
        type VTDocument = Document & {
          startViewTransition?: (cb: () => void) => {
            finished: Promise<void>;
            ready: Promise<void>;
            updateCallbackDone: Promise<void>;
          };
        };
        const vtDoc = document as VTDocument;

        modeToggleBtn?.addEventListener('click', () => {
          // Stop the periodic attention-pulse (see .home-toggle--used in
          // the <style> block) for good once the visitor has actually
          // found and used the control — no reason to keep nudging it.
          modeToggleBtn.classList.add('home-toggle--used');

          const goingToGrid = root!.dataset.displayMode === 'carousel';

          // Accessible name flips synchronously, outside the transition
          // callback — correct even before the (possibly deferred-a-frame)
          // DOM mutation below runs.
          modeToggleBtn.setAttribute(
            'aria-label',
            goingToGrid ? modeToggleBtn.dataset.labelCarousel ?? '' : modeToggleBtn.dataset.labelGrid ?? '',
          );

          // Re-point the shared-element morph name to whichever gallery the
          // carousel currently shows (it auto-advances), so both toggle
          // directions morph the correct tile rather than always the first.
          if (namedMorphTile) {
            namedMorphTile.style.viewTransitionName = '';
          }
          const morphTarget = gridGalleryTiles[carouselIndex] ?? null;
          if (morphTarget) {
            morphTarget.style.viewTransitionName = 'ajs-hero-morph';
          }
          namedMorphTile = morphTarget;

          const mutate = goingToGrid ? showGrid : showCarousel;

          if (typeof vtDoc.startViewTransition === 'function') {
            vtDoc.startViewTransition(mutate);
          } else {
            mutate();
          }
        });

        render();
        startAutoAdvance();

        // Re-align the wordmark cutout on resize — both the hero photo's
        // rendered size and the wordmark's own position within it change
        // at different viewport widths (see the mobile-width overrides
        // above), so a stale computed --wordmark-bg-size/-position from a
        // previous width would drift out of alignment.
        let resizeTimer: ReturnType<typeof setTimeout> | null = null;
        window.addEventListener('resize', () => {
          if (resizeTimer) clearTimeout(resizeTimer);
          resizeTimer = setTimeout(syncWordmarkAlignment, 100);
        });
      }
    </script>
  </section>
)}

<style>
  .home-empty {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-md);
    text-align: center;
    font-size: 16px;
  }

  .home {
    position: relative;
  }

  /* Top bar — carousel mode: overlaid on the hero photo, colored with the
     current accent (UI-SPEC Layout Notes — Header). Grid mode: static
     position, ink-colored (no image beneath it). */
  .home-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-md);
    z-index: 5;
    /* Direct follow-up (quick-260713-jfz): same class of bug as
       .home-hero__accent's view-transition-name above — unnamed, the
       header was just part of the flat root snapshot, and since it comes
       BEFORE .home-hero__photo in DOM order, default paint-order stacking
       would put its own group BELOW ajs-hero-morph too (root-relative
       DOM position, not just "unnamed vs named", determines default
       stacking — see the explicit z-index below, which is what actually
       fixes it). The morphing photo's box overlaps the header's screen
       area while growing/shrinking, fully blanking the logo/nav/toggle for
       a visible chunk of the transition — confirmed via a cropped
       mid-transition screenshot showing the header region completely
       empty. Naming it (plus the explicit z-index in the is:global block)
       keeps it in its own group, painted above the morph regardless of
       DOM order. */
    view-transition-name: ajs-header;
  }

  .home[data-display-mode='carousel'] .home-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0) 100%);
    /* Neutral white, not the cycling accent color (direct user feedback —
       the accent-per-gallery color is reserved for the accent panel only,
       per D-05; header/nav text should read for contrast, not compete with
       it). */
    color: #FFFFFF;
  }

  .home[data-display-mode='grid'] .home-header {
    position: static;
    background: none;
    color: var(--color-ink);
  }

  /* D-01/D-02 (revised per logo-hover-and-font debug session): two
     normal-flow <img> elements, hard display:none/block swap on hover —
     mirrors BaseLayout.astro's .logo-mark mechanism exactly (matches the
     reference site's own hover MECHANIC, verified byte-for-byte against its
     compiled CSS: a display:none/block toggle between two same-size images,
     no transition/opacity), scoped by data-display-mode instead of a
     site-header--solid/--transparent class. Deliberately NOT
     absolutely-positioned — an earlier version stacked the hover image with
     `position: absolute` while the default used `display: none` on hover,
     which collapsed `.home-logo`'s own box to 0x0 (no in-flow child left)
     and shifted the sibling nav layout on hover. Both logo PNGs share the
     same intrinsic aspect ratio, so swapping which one is in-flow causes no
     layout jump.

     The dark `__chip` backdrop is KEPT (unlike the original fix plan) but
     changed from an opacity-fade to the same instant display:none/block
     toggle as the images — see BaseLayout.astro's matching comment: the
     reference site's own rollover PNG asset has an opaque black background
     baked into the file itself (verified by downloading and viewing it),
     which is how it stays legible over a white header. Our white logo
     variant is a transparent PNG, so without an instant backdrop the hover
     state is nearly invisible against the light grid-mode header. */
  .home-logo {
    position: relative;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .home-logo__chip {
    position: absolute;
    inset: calc(-1 * var(--space-sm));
    background-color: var(--color-ink);
    border-radius: var(--radius-none);
    display: none;
    z-index: 0;
  }

  .home-logo__img {
    position: relative;
    z-index: 1;
    display: block;
    width: 56px;
    height: auto;
  }

  .home-logo__img--hover {
    display: none;
  }

  /* Grid mode mirrors .site-header--solid: default = black logo;
     hover/focus-within hard-swaps to the white variant over the instantly-
     shown dark chip, no transition. */
  .home[data-display-mode='grid'] .home-logo:hover .home-logo__img--default,
  .home[data-display-mode='grid'] .home-logo:focus-within .home-logo__img--default {
    display: none;
  }

  .home[data-display-mode='grid'] .home-logo:hover .home-logo__img--hover,
  .home[data-display-mode='grid'] .home-logo:focus-within .home-logo__img--hover,
  .home[data-display-mode='grid'] .home-logo:hover .home-logo__chip,
  .home[data-display-mode='grid'] .home-logo:focus-within .home-logo__chip {
    display: block;
  }

  /* Carousel mode mirrors .site-header--transparent (revised per
     logo-hover-and-font debug session, Round 2): white logo variant shown by
     default over the existing hero gradient scrim — unchanged. Hover/
     focus-within now hard-swaps to the BLACK variant, same mechanic as grid
     mode, but with a LIGHT chip instead of grid mode's dark chip — the black
     hover-logo would be invisible against both the dark hero photo and a
     dark chip, so the backdrop color must flip with the logo color. */
  .home[data-display-mode='carousel'] .home-logo__img--default {
    display: none;
  }

  .home[data-display-mode='carousel'] .home-logo__img--hover {
    display: block;
  }

  .home[data-display-mode='carousel'] .home-logo:hover .home-logo__img--hover,
  .home[data-display-mode='carousel'] .home-logo:focus-within .home-logo__img--hover {
    display: none;
  }

  .home[data-display-mode='carousel'] .home-logo:hover .home-logo__img--default,
  .home[data-display-mode='carousel'] .home-logo:focus-within .home-logo__img--default,
  .home[data-display-mode='carousel'] .home-logo:hover .home-logo__chip,
  .home[data-display-mode='carousel'] .home-logo:focus-within .home-logo__chip {
    display: block;
  }

  /* Mode-aware chip color: grid mode's chip (behind the white hover-logo,
     base .home-logo__chip rule above) stays dark (--color-ink) — this
     override only applies in carousel mode, behind the black hover-logo, so
     it must be light instead. */
  .home[data-display-mode='carousel'] .home-logo__chip {
    background-color: var(--color-dominant);
  }

  .home-nav {
    margin-right: auto;
    margin-left: var(--space-md);
    display: flex;
    gap: var(--space-md);
  }

  /* LanguageSwitcher.astro hardcodes its own links pink (correct everywhere
     else on the site, D-06) — but the homepage's own top bar is neutral
     white/ink throughout (see .home-header color above), so the switcher
     needs its own override here too. Scoped to .home-header only so
     LanguageSwitcher's behavior everywhere else (BaseLayout's solid/
     transparent headers) is untouched. */
  .home[data-display-mode='carousel'] .home-header :global(.switcher-link),
  .home[data-display-mode='carousel'] .home-header :global(.switcher-separator) {
    color: #FFFFFF;
  }

  .home[data-display-mode='grid'] .home-header :global(.switcher-link),
  .home[data-display-mode='grid'] .home-header :global(.switcher-separator) {
    color: var(--color-ink);
  }

  .home-nav-link,
  .home-toggle {
    display: inline-flex; /* matches LanguageSwitcher's .switcher-link so text
                              baselines line up across the whole header —
                              a plain block/inline box top-aligns its text
                              within the min-height box instead of centering
                              it, which read as misaligned buttons */
    align-items: center;
    font-size: 14px; /* Label role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    color: inherit;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs) var(--space-sm);
    min-height: var(--tap-target-min);
  }

  .home-nav-link:hover,
  .home-nav-link:focus-visible {
    text-decoration: underline;
  }

  /* Direct user feedback: the bare 20x20 icon (no border/background) didn't
     read as an interactive button among the nav's plain text links — give
     it a visible box so it looks distinctly clickable, matching the site's
     square-cornered (--radius-none) brutalist language rather than a
     rounded chip. */
  .home-toggle {
    border: 1.5px solid currentColor;
    padding: var(--space-xs);
  }

  .home-toggle:hover,
  .home-toggle:focus-visible {
    background-color: currentColor;
  }

  .home-toggle:hover .home-toggle__morph-cell,
  .home-toggle:focus-visible .home-toggle__morph-cell {
    /* Invert the cells' own fill against the now-solid currentColor
       background above (background-color, not color — each cell paints
       itself via background-color: currentColor, not an SVG stroke/fill),
       so they stay visible instead of disappearing into a same-color
       backdrop. */
    background-color: var(--current-accent, var(--color-accent));
  }

  .home[data-display-mode='grid'] .home-toggle:hover .home-toggle__morph-cell,
  .home[data-display-mode='grid'] .home-toggle:focus-visible .home-toggle__morph-cell {
    background-color: var(--color-dominant);
  }

  /* Direct user feedback: draw temporary attention to the toggle so first-
     time visitors notice it exists, without permanently animating a control
     they've already found. A bounded pulse (3 iterations, ~1.5s total)
     starting shortly after the page settles. Direct follow-up feedback:
     visitors may not be looking at exactly that moment, so this repeats
     periodically (a brief double-pulse every 6s, mostly at rest in
     between) rather than firing once and going quiet for good — "pour
     attirer l'oeil" even without a click. Stops permanently once the
     visitor actually clicks it (see .home-toggle--used below, set by the
     click handler in the <script> block) — no reason to keep nudging a
     control they've already found and used. Respects
     prefers-reduced-motion throughout. */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes home-toggle-attention {
      0%,
      75%,
      100% {
        transform: scale(1);
      }
      82%,
      92% {
        transform: scale(1.15);
      }
      87% {
        transform: scale(1);
      }
    }

    .home-toggle:not(.home-toggle--used) {
      animation: home-toggle-attention 6s ease-in-out infinite;
      animation-delay: 1.2s;
    }
  }

  /* D-01 (revised per direct user reference — a "carousel to grid material
     icon" morph animation, not a hard icon swap): a single 6-cell CSS grid
     icon (2 rows x 3 cols, matching the reference image exactly) whose gap
     animates between two states, rather than two separate SVGs shown/
     hidden via display. When gap is 0, each row's 3 cells sit flush against
     each other with no visible seam (same solid currentColor fill, no
     border) and read as one continuous bar — the carousel/list glyph. When
     gap opens up, the same 6 cells read as a 3x2 grid — the grid glyph.
     Only the gap value changes; the 6 elements themselves never move,
     resize, or get replaced, so the browser can animate the transition
     smoothly for free via `transition: gap`. */
  .home-toggle__morph {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    width: 20px;
    height: 14px;
    /* row-gap is fixed, never animated — it's what keeps the icon reading
       as "2 bars" even once each bar's 3 cells merge into one (see
       column-gap below). Animating the shorthand `gap` collapsed row-gap
       to 0 too, which merged all 6 cells into a single solid block instead
       of two distinct bars — confirmed via a live screenshot before this
       fix, not guessed. */
    row-gap: 2px;
    column-gap: 0;
    transition: column-gap 280ms ease;
  }

  .home-toggle__morph-cell {
    background-color: currentColor;
  }

  /* Icon shown is the icon of the mode you'd switch TO, mirroring the
     aria-label (unchanged from D-01's original intent) — carousel mode
     shows the grid glyph (gap open), grid mode shows the bars glyph
     (gap closed). */
  .home[data-display-mode='carousel'] .home-toggle__morph {
    column-gap: 2px;
  }

  .home[data-display-mode='grid'] .home-toggle__morph {
    column-gap: 0;
  }

  /* Carousel mode — full-viewport hero photo + scrim + caption + accent
     panel (D-08/D-09, UI-SPEC Layout Notes — Homepage Carousel mode).
     The UI-SPEC's original min-height floor (680px, then lowered to 600px)
     still cropped the hero on a real MacBook Air 13" (confirmed by direct
     user report both times) — any fixed floor can exceed an unknown real
     window's innerHeight. Removed entirely: height:100vh alone can never
     exceed the actual viewport, so this eliminates the whole bug class
     instead of chasing another guessed pixel value. */
  .home-hero {
    position: relative;
  }

  /* Photo + its overlaid chrome (scrim, arrows, caption) — sized
     independently of .home-hero__accent, which on mobile is an in-flow
     sibling below (see its mobile override) and would otherwise force
     .home-hero itself to grow taller than the photo. Everything visually
     "part of the photo" is absolutely positioned against *this* box, so it
     stays confined to a proper 16:9 band no matter how tall the panel
     below makes .home-hero grow. */
  .home-hero__photo {
    position: relative;
    /* Explicit width required: without it, the browser treats aspect-ratio
       + max-height together as "solve for width" once max-height clamps
       the height, shrinking the hero narrower than the viewport (confirmed
       via live measurement — a 1920x700 window produced a 1244px-wide
       hero, leaving visible gaps left/right) instead of just capping
       height and keeping it full-bleed. */
    width: 100%;
    aspect-ratio: 16 / 9;
    /* Without a ceiling, aspect-ratio derives height purely from width — on
       a wide/short browser window that height can exceed the actual
       viewport (unlike the previous height:100vh, which was always capped
       to the viewport by definition), making the whole page noticeably
       taller/scrollier than before. max-height keeps the 16:9 look on
       narrower windows while never letting the hero alone exceed one
       screen's height. */
    max-height: 100vh;
    overflow: hidden;
    /* Shared-element morph target (quick-260713-jfz): names this real
       component element so the View Transitions engine treats it as the
       "old" or "new" state of the ajs-hero-morph pair, morphing it to/from
       whichever grid tile is JS-named the same in the <script> above.
       Regular scoped styling — this is a real element, not a
       document-level ::view-transition-* pseudo-element (those require
       :global below). */
    view-transition-name: ajs-hero-morph;
  }

  .home-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.15) 45%, rgba(0, 0, 0, 0) 70%);
  }

  /* Replaces the old prev/next arrow buttons. Direct follow-up feedback:
     moved from a full-width bar below the header to a compact one nested
     inside .home-hero__caption (bottom-left, in normal flow above the
     index/title/byline) — no absolute positioning of its own needed, it
     just sits wherever the caption already sits. Width is capped well
     under the caption's own 60% max-width per the "20-30% max of the page
     width" request — min() keeps it from ballooning on very wide desktop
     windows while staying comfortably tappable (3 dashes + gaps) on
     narrow phones. */
  .home-hero__progress {
    display: flex;
    gap: var(--space-xs);
    width: min(25vw, 220px);
    margin: 0 0 var(--space-sm);
  }

  .home-hero__progress-dash {
    position: relative;
    flex: 1 1 0;
    height: 3px;
    padding: 0;
    border: none;
    border-radius: var(--radius-none);
    background: rgba(255, 255, 255, 0.35);
    cursor: pointer;
  }

  /* Invisible hit-area extension — a 3px-tall bar is far below the
     var(--tap-target-min) (44px) accessible tap-target size, so this
     enlarges the clickable/tappable region vertically without changing
     the dash's own visual thickness. */
  .home-hero__progress-dash::before {
    content: '';
    position: absolute;
    inset: calc(-1 * var(--space-md)) 0;
  }

  .home-hero__progress-dash[aria-current='true'] {
    background: var(--current-accent, var(--color-accent));
  }

  .home-hero__progress-dash:hover,
  .home-hero__progress-dash:focus-visible {
    background: rgba(255, 255, 255, 0.65);
  }

  .home-hero__progress-dash[aria-current='true']:hover,
  .home-hero__progress-dash[aria-current='true']:focus-visible {
    background: var(--current-accent, var(--color-accent));
  }

  .home-hero__progress-dash:focus-visible {
    outline: 2px solid #FFFFFF;
    outline-offset: 3px;
  }

  .home-hero__caption {
    position: absolute;
    left: var(--space-md);
    bottom: var(--space-xl);
    max-width: 60%;
    z-index: 3;
    color: #FFFFFF;
  }

  .home-hero__index {
    font-size: 14px; /* Label role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 var(--space-xs);
  }

  .home-hero__title {
    font-family: var(--font-display);
    font-size: 20px; /* Heading role */
    font-weight: var(--weight-semibold);
    line-height: 1.2;
    margin: 0 0 var(--space-xs);
    color: #FFFFFF;
    /* Direct user feedback: nothing distinguished this from a plain
       caption heading, so visitors weren't discovering it's a link to the
       gallery. Persistent underline (not hover-only — hover affordances
       don't help touch/mobile users decide whether to tap in the first
       place) plus a visible hover/focus state for pointer users. */
    text-decoration: underline;
    text-underline-offset: 3px;
    display: inline-block;
  }

  .home-hero__title:hover,
  .home-hero__title:focus-visible {
    color: var(--current-accent, var(--color-accent));
  }

  .home-hero__byline {
    font-size: 14px; /* Label role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }

  .home-hero__accent {
    position: absolute;
    right: var(--space-md);
    bottom: var(--space-md);
    /* Widened again for the 80px wordmark (below, up from 64px): live-
       measured "JACQUELINE" at 80px is ~682px wide including letter-
       spacing, which needed more room than the previous 680px panel
       (616px inner width) could fit. 800px gives ~736px of inner width,
       comfortable clearance for the widest line. */
    width: min(800px, 60%);
    padding: var(--space-xl);
    z-index: 3;
    /* Direct follow-up (quick-260713-jfz): without its own name, this panel
       was just part of the flat "everything else" root snapshot, painted
       BELOW the named ajs-hero-morph group in the view-transition overlay's
       default stacking order. Since the panel geometrically overlaps the
       photo in its final position, the still-growing photo morph visually
       covered it for the whole transition — it only became visible once the
       overlay tore down and real DOM stacking (z-index: 3, above the photo)
       took over, reading as a sudden pop instead of the fade-in it was meant
       to be. Naming it gives it its own group in the pseudo-element tree,
       stacked above ajs-hero-morph (it comes later in DOM/paint order), so
       it can fade in independently and stay visible throughout. It has no
       "old" counterpart on the grid side (the whole .home-hero is hidden in
       grid mode), so this is a pure enter/exit fade — no shape to morph. */
    view-transition-name: ajs-accent-panel;
    /* Solid "paper" backing for the whole panel (wordmark + intro together),
       cycling per-gallery via --current-accent (set by render()). This is
       what makes the wordmark below read as letters CUT OUT of a solid
       sheet, revealing the photo behind through the cutout shapes, rather
       than ghostly text floating directly on the photo with no panel at
       all — corrected per direct user feedback (the panel background was
       removed entirely in an earlier pass; that was the wrong reading of
       D-08, which only meant the WORDMARK's own fill should reveal the
       photo, not that the surrounding panel should have no backing). */
    background-color: var(--current-accent, var(--color-accent));
  }

  /* D-07/D-08/D-09: carousel-mode wordmark cutout — the letters themselves
     have no solid fill (see @supports block below), so wherever a glyph
     shape sits, .home-hero__accent's own solid background (above) is
     overpainted by --wordmark-photo instead — a true papercut effect: solid
     panel everywhere except the exact letter shapes, which show the photo
     behind. Outside the glyphs, the panel's plain solid color shows through
     normally, since the wordmark element itself has no background of its
     own beyond the text fill. */
  .home-hero__wordmark {
    font-family: var(--font-display);
    /* Matches the gallery caption title convention elsewhere in this same
       component (.home-hero__title / grid tile titles both render via
       .toUpperCase() — see "SILOS" in the caption), and the AJS logo mark
       itself, which is all-caps. Direct user feedback — the wordmark should
       read consistently with those, not mixed-case. */
    text-transform: uppercase;
    /* Fluid, not a flat 80px: a fixed font-size paired with the panel's
       percentage-driven width (min(800px, 60%), above) only matched at the
       exact viewport widths it was spot-checked at — live-measured a real
       overflow zone between ~1000-1230px viewport width, where 60% of the
       viewport produces a narrower panel than the flat 80px text needs
       (confirmed via a live screenshot showing "JACQUELINE"/"SUZANNE"
       clipped past the panel edge, not guessed). clamp(44px, 6vw, 80px)
       tracks the SAME 60vw rate the panel width uses below the 1333px
       breakpoint where the panel's own min(800px, 60%) switches from
       percentage to its flat cap — so the font-to-panel-width ratio stays
       constant across the entire desktop range instead of only being
       correct at whichever handful of widths got spot-checked. Re-verified
       across the full 768-1920px range after this fix, not just the
       previously-broken zone. */
    font-size: clamp(44px, 6vw, 80px);
    font-weight: var(--weight-semibold);
    /* 0.9 — deliberately tight, not the previous 1.6: direct user request
       to "strongly reduce the gap between the lines." Verify live that
       Unbounded's glyphs (different metrics than Anton, which needed 1.6 to
       avoid real box overlap) don't visually collide/become illegible at
       this tightness — tight-but-legible is the goal, not overlapping. */
    line-height: 0.9;
    letter-spacing: 0.02em;
    margin: 0 0 var(--space-md);
    /* Fallback (unsupported engines, effectively unreachable in 2026
       evergreen browsers): solid on-accent color, no background-image, so
       the wordmark is never invisible/blank. */
    color: var(--color-on-accent);
  }

  @supports (background-clip: text) or (-webkit-background-clip: text) {
    .home-hero__wordmark {
      background-image: var(--wordmark-photo);
      /* --wordmark-bg-size/-position are computed live by
         syncWordmarkAlignment() in the <script> below, so the visible
         slice lines up with the exact same crop of the photo that's
         actually behind the panel (a true cutout), not an independently
         re-cropped/zoomed copy. cover/center are fallbacks only — for the
         brief window before JS first runs, or if it never runs at all. */
      background-size: var(--wordmark-bg-size, cover);
      background-position: var(--wordmark-bg-position, center);
      /* Without this, a stale/out-of-range --wordmark-bg-position (e.g. the
         mobile fallback path, which never sets it, or any future edge
         case where the computed offset exceeds the background image's own
         size) tiles into a repeated, garbled texture instead of just
         clipping — confirmed as the cause of a reported "transparency
         effect doesn't work" regression. */
      background-repeat: no-repeat;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
      /* Live-verification finding (Task 3): the plain cutout is illegible
         wherever the underlying photo crop is busy/low-contrast near a
         letter's edge (confirmed on both the Silos and Brume galleries — the
         third line consistently vanished into the photo). A soft dark
         text-shadow paints around the glyph outline (independent of the
         transparent fill) to give every letter a contrast edge against any
         photo content, without adding a solid backing that would defeat the
         cutout (D-08's own "must be verified live, must remain legible"
         requirement, resolved via Claude's discretion per D-08/D-09). */
      text-shadow: none; /* temporarily removed for comparison, per user request */
    }
  }

  .home-hero__intro {
    font-size: 16px; /* Body role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    margin: 0;
    /* No background of its own — .home-hero__accent's solid panel background
       (above) now covers the whole panel, wordmark included, so a separate
       backing here would just repaint the same color redundantly. */
    padding: var(--space-sm) var(--space-md);
  }

  /* D-04/D-05/D-06: grid-mode hero is now the first *tile* of the grid
     itself (not a full-width band) — a non-link <div>, same square sizing
     as every gallery tile, solid accent background (no photo/cutout).
     Compound selector (.home-grid__tile.home-grid__tile--hero), not a bare
     .home-grid__tile--hero: the generic .home-grid__tile rule below shares
     this element (both classes are on the same <div>) and also sets
     `display`, at equal single-class specificity — since it appears later
     in source order it was silently winning and collapsing this rule's
     `display: flex` back to `display: block`, losing the vertical-centering
     layout (confirmed via getComputedStyle: display read "block" here
     despite this rule; aspect-ratio/position/overflow were unaffected since
     only .home-grid__tile itself declares those). The two-class selector
     raises specificity so this rule's `display` always wins regardless of
     source order. */
  .home-grid__tile.home-grid__tile--hero {
    background-color: var(--current-accent, var(--color-accent));
    color: var(--color-on-accent);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .home-grid__wordmark {
    font-family: var(--font-display);
    text-transform: uppercase;
    /* 40px desktop — bumped from 24px (direct user feedback: too small,
       inconsistent visual weight next to the carousel version). Live-
       measured against the hero-tile's actual inner width (395px at a
       1280px viewport, 3-column grid): "JACQUELINE" (the widest line) is
       only 341px at 40px, comfortable margin, well short of the earlier
       overflow problems the carousel version hit at its much larger sizes.
       No cutout here (D-05) — stays solid --font-display text in
       --color-on-accent. */
    font-size: 40px;
    font-weight: var(--weight-semibold);
    line-height: 1.15;
    letter-spacing: 0.02em;
    margin: 0 0 var(--space-sm);
  }

  .home-grid__intro-body {
    font-size: 14px; /* Label role — down from 16px Body, same fit constraint */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-grid__tiles {
    display: grid;
    /* 3, not 2 — direct user feedback that tiles were too big at 2 columns
       (each roughly half the viewport width). */
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .home-grid__tile {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    text-decoration: none;
  }

  .home-grid__tile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .home-grid__tile-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.15) 45%, rgba(0, 0, 0, 0) 70%);
  }

  .home-grid__tile-title {
    position: absolute;
    left: var(--space-md);
    bottom: var(--space-md);
    z-index: 2;
    font-family: var(--font-display);
    font-size: 32px; /* Display role, fixed */
    font-weight: var(--weight-semibold);
    line-height: 1.2;
    color: #FFFFFF;
  }

  /* Mobile responsive (D-10, UI-SPEC Layout Notes — Homepage Mobile). */
  @media (max-width: 767px) {
    /* Direct request: FR|EN belongs in the top row alongside the logo/nav/
       toggle, not wrapped onto its own row underneath. Live-measured at
       393px wide: logo(56) + nav(157) + toggle(30) + switcher(79) plus
       .home-header's own gap between all four (3 × 16px) totals 386px —
       10px over the 361px available (393 minus the header's own 32px of
       side padding) BEFORE even counting .home-nav's extra margin-left
       (below), which was adding a redundant second gap on top of the
       header's own flex gap between the logo and nav specifically. Trimming
       both — the header's inter-item gap and that redundant nav margin —
       recovers ~40px, comfortably fitting all four on one row (measured
       346px used of 361px available). flex-wrap stays on as a safety net
       for narrower phones or longer translated labels; it just no longer
       needs to trigger at this width. */
    .home-header {
      flex-wrap: wrap;
      gap: var(--space-sm);
    }

    .home-nav {
      margin-left: 0;
    }

    /* Direct request: the photo should cover the full phone screen on
       arrival, like a true full-bleed mobile hero. .home-hero__photo
       already has max-height:100vh from the base rule; pairing it with an
       equal min-height forces the full viewport height regardless of the
       16:9 aspect-ratio, and object-fit:cover on .home-hero__img (unchanged)
       naturally crops/zooms the photo to fill that box — a portrait phone
       screen against a landscape photo crops in hard on its own, no extra
       transform needed. The base rule's top:50% arrow centering and
       bottom-anchored caption both now measure against this same
       full-viewport box, so nothing needs a mobile-specific override —
       centering in "the whole screen" is exactly right for a full-bleed
       hero.

       100svh, not 100vh: confirmed via a real-device screenshot that plain
       vh (which resolves to the LARGE viewport, i.e. the size once
       Safari's address bar auto-hides) made the hero taller than what's
       actually visible on first load, while the browser chrome is still
       showing — the site's own footer text peeked in underneath the
       caption on arrival. svh always resolves to the SMALL viewport (chrome
       visible, the worst case), so the hero is guaranteed to fit within
       whatever is actually on screen before any scrolling happens. */
    .home-hero__photo {
      min-height: 100svh;
    }

    /* Direct follow-up: an in-flow panel below the photo (previous pass)
       required scrolling to see it, but "on the picture" was the whole
       point — the panel needs to overlay the full-bleed photo, not follow
       it. Back to position:absolute (like the desktop corner card), just
       anchored full-width along the bottom instead of a bottom-right
       corner. bottom offset reserves room for .home-hero__caption (now
       progress dashes + index + title + byline, live-remeasured at 85px
       tall after the dashes moved in above the index line — was 74px
       before) below the panel plus its own --space-xl gap to the screen
       edge, so the two overlaid layers stack without covering each other.
       Re-verify this number any time .home-hero__caption's own content
       changes — it's a live measurement, not a derived value. */
    .home-hero__accent {
      position: absolute;
      left: 0;
      right: 0;
      bottom: calc(85px + var(--space-xl) + var(--space-md));
      width: 100%;
      margin-top: 0;
      /* Direct request: shrink the panel itself so less of the screen is
         solid color and more of the photo shows above it. Tighter padding
         than the desktop var(--space-xl) (32px) reduces the panel's
         footprint on all four sides and, as a side effect, widens the
         wordmark's own inner width — more room to grow it further below. */
      padding: var(--space-lg);
    }

    /* D-09/direct follow-up ("more bigger!"): pushed further than the
       first pass, using the room freed up by .home-hero__accent's tighter
       mobile padding above (var(--space-lg), not the desktop var(--space-xl))
       — a wider inner width for the same viewport. Re-measured the same
       way (actual rendered line width via Range.getBoundingClientRect()
       across 360-767px): clamp(36px, 9.8vw, 50px) keeps at least a 5px
       margin everywhere, with most of the common phone range (390-428px)
       sitting at 16-23px of margin. 360px now floors at 36px (up from the
       previous pass's 34px); ~390-428px renders 38-42px (up from 36-39px);
       cap raised from 46px to 50px for wider viewports. */
    .home-hero__wordmark {
      font-size: clamp(36px, 9.8vw, 50px);
    }

    /* Direct request: shrink the intro paragraph to make room for a bigger
       wordmark and a shorter overall panel — 14px (Label role, matching
       .home-hero__index/__byline elsewhere in this component) instead of
       the desktop 16px (Body role). */
    .home-hero__intro {
      font-size: 14px;
      line-height: 1.4;
    }

    /* Grid hero-tile wordmark — mobile-width override (Typography table).
       Deliberate mobile-only reversal of D-05 (see 06-DISCUSSION-LOG.md):
       (a) the grid hero tile was flat 16px solid text on mobile, too small
       and visually inconsistent with the carousel's photo-cutout wordmark —
       direct live-device feedback asked for the same effect here; (b) sized
       with the carousel's proven starting clamp (see Task 2 for the final
       live-measured bounds); (c) desktop (`.home-grid__wordmark` above,
       outside this media query) is untouched — still solid --color-on-accent
       text, no cutout. */
    .home-grid__wordmark {
      font-size: clamp(36px, 9.8vw, 50px);
    }

    /* --wordmark-photo is inherited from the .home root (server-rendered,
       re-set on every carousel tick) — no JS change needed here, it's
       already the "photo displayed on the carousel behind" for whichever
       gallery the carousel last showed. Unlike the carousel wordmark, the
       grid hero tile has no photo physically behind it to pixel-align to
       (it's a solid-accent square), so this uses the same cover/center
       fallback values the carousel's own @supports block falls back to
       before JS runs — not syncWordmarkAlignment()'s live-computed
       --wordmark-bg-size/--wordmark-bg-position, which would be meaningless
       here. Fallback (unsupported engines): the base rule's solid
       --color-on-accent color above still applies since it's outside this
       @supports block. */
    @supports (background-clip: text) or (-webkit-background-clip: text) {
      .home-grid__wordmark {
        background-image: var(--wordmark-photo);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        -webkit-text-fill-color: transparent;
      }
    }

    .home-grid__tiles {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  /* View Transitions pseudo-elements (quick-260713-jfz) live on the document
     root, outside this component's subtree — Astro's scoped <style> above
     cannot target ::view-transition-*, so this must be a global block.
     Customizes the swap's timing beyond the browser's flat ~250ms default
     cross-fade: a deliberate ~420ms root cross-fade plus the shared-element
     ajs-hero-morph group (named on .home-hero__photo above and on the
     matching grid tile by the <script> block), so the hero photo visibly
     grows/shrinks/repositions toward its grid tile instead of just fading. */
  /* Explicit stacking, unconditional (not just under no-preference — wrong
     stacking would be just as visible, if briefly, even at reduced-motion
     durations). Default view-transition-group stacking follows DOM/paint
     order, which put ajs-header (comes BEFORE .home-hero__photo in the
     markup) and, less obviously, ajs-accent-panel too, at the mercy of
     that ordering rather than a guarantee. Named groups default to normal
     stacking (root at the back); giving ajs-hero-morph the lowest explicit
     z-index and the header/panel higher ones guarantees both always paint
     above the morphing photo regardless of markup order, instead of
     relying on "it happens to come after in the DOM." */
  ::view-transition-group(ajs-hero-morph) {
    z-index: 1;
  }

  ::view-transition-group(ajs-header),
  ::view-transition-group(ajs-accent-panel) {
    z-index: 2;
  }

  @media (prefers-reduced-motion: no-preference) {
    ::view-transition-old(root),
    ::view-transition-new(root),
    ::view-transition-group(ajs-hero-morph) {
      animation-duration: 420ms;
      animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* quick-260713-kit: locally-defined keyframes for the accent panel's
       enter/exit fade, referenced via the FULL `animation` shorthand
       (name + duration + timing + delay + fill-mode) below, instead of
       the previous longhand-only override (duration/delay/timing-function
       only). The longhand-only rule left animation-name and
       animation-fill-mode to fall through the cascade from the browser's
       own UA view-transition stylesheet — in the Chromium version used for
       this fix, that UA default already happens to be `both`, so the
       delay-window hold-at-0 already worked there, but relying on an
       unspecified, engine-defined default for a load-bearing visual
       guarantee is fragile (other engines are not guaranteed to default to
       `both`). Setting the full shorthand replaces 100% of the animation
       sub-properties, so the fade no longer depends on any UA default. */
    @keyframes ajs-panel-fade-in {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes ajs-panel-fade-out {
      from {
        opacity: 1;
      }
      to {
        opacity: 0;
      }
    }

    /* Direct follow-up: the accent panel (ajs-accent-panel, named above)
       gets its own fade rather than riding along with the root cross-fade —
       naming it moves it into its own group, stacked above ajs-hero-morph,
       so it's no longer hidden behind the still-growing photo for the whole
       transition (see the comment on .home-hero__accent's view-transition-
       name for the full root-cause). A short delay after the photo starts
       morphing, rather than an identical simultaneous fade, reads as a
       deliberate staggered reveal — the photo settles into place, then the
       panel fades in over it — instead of everything happening at once. */
    ::view-transition-new(ajs-accent-panel) {
      animation: ajs-panel-fade-in 380ms cubic-bezier(0.4, 0, 0.2, 1) 100ms both;
    }

    /* Exit fade (carousel->grid direction) — no entrance delay needed
       here, live measurement showed the exit already reads smoothly with
       an immediate fade-out. */
    ::view-transition-old(ajs-accent-panel) {
      animation: ajs-panel-fade-out 380ms cubic-bezier(0.4, 0, 0.2, 1) both;
    }

    /* Direct follow-up: the header (ajs-header, named above) was fully
       blanked out for a visible chunk of the transition — the morphing
       photo's box overlapped its screen area while the header was still
       painted in the (wrongly-stacked) root layer beneath it. Unlike the
       accent panel, the header is present in BOTH the carousel and grid
       states (just restyled — gradient-over-photo vs solid background), so
       this is a genuine cross-fade of its two appearances, not an
       enter/exit — no entrance delay needed, just the same duration as
       everything else for a consistent feel. */
    ::view-transition-old(ajs-header),
    ::view-transition-new(ajs-header) {
      animation-duration: 420ms;
      animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    }
  }

  /* The View Transitions API does not honor prefers-reduced-motion on its
     own — this explicit override is required to keep the swap effectively
     instant for reduced-motion users, mirroring how .home-toggle--used's
     attention-pulse (above) is already gated behind the same query. */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-group(*),
    ::view-transition-old(*),
    ::view-transition-new(*) {
      animation: none !important;
    }
  }
</style>
