---
// Single-link locale switcher (I18N-04, D-07-D-11): one <a> pointing at the
// OTHER language's version of the current page, preceded by an inline
// dependency-free globe <svg> and a visible EN/FR code. getSwitcherHref is
// called once, for the non-current locale only (D-08).
import { getSwitcherHref } from '../lib/i18n-paths';

const currentLocale = Astro.currentLocale === 'en' ? 'en' : 'fr';
const targetLocale = currentLocale === 'fr' ? 'en' : 'fr';
const targetHref = getSwitcherHref(Astro.url.pathname, targetLocale);
const targetLabel = targetLocale === 'en' ? 'EN' : 'FR';
// D-11: mirrors BaseLayout.astro's existing instagramNewTabHint sr-only
// pattern — locale-conditional hidden hint naming the language you'd switch
// TO, phrased in the CURRENT page's language (not the target's).
const switchHint = currentLocale === 'fr' ? 'Passer en anglais' : 'Switch to French';
---

<nav class="language-switcher" aria-label="Language switcher">
  <a href={targetHref} class="switcher-link" data-locale={targetLocale}>
    <svg
      aria-hidden="true"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
    >
      <circle cx="12" cy="12" r="9.5" />
      <ellipse cx="12" cy="12" rx="4.2" ry="9.5" />
      <line x1="2.5" y1="12" x2="21.5" y2="12" />
    </svg>
    {targetLabel}
    <span class="sr-only">{' '}{switchHint}</span>
  </a>
</nav>

<style>
  .language-switcher {
    display: inline-flex;
    align-items: center;
    font-size: 14px; /* Label role */
    font-weight: 400;
    line-height: 1.5;
  }

  .switcher-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs); /* space between globe icon and label */
    min-height: 44px; /* WCAG 2.5.5 tap-target floor, applied via padding not font-size */
    padding: 8px; /* sm spacing token */
    color: var(--color-accent); /* D-06: switcher links render pink */
    text-decoration: none;
  }

  .switcher-link:hover,
  .switcher-link:focus-visible {
    text-decoration: underline;
  }

  .switcher-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

<script>
  const COOKIE_NAME = 'ajs_locale';

  // WR-02: `import.meta.env.BASE_URL` is one of the env vars Astro/Vite
  // statically replaces in client bundles too (not just frontmatter), so this
  // works the same way BaseLayout's inline redirect script derives its base.
  // Scoping the cookie's path to the deployed base — "/" on OVH production,
  // "/ajs-website/" on GitHub Pages staging — matters because GitHub Pages
  // project sites share the `github.io` user domain: an unscoped `path=/`
  // cookie would be sent on every request to *any* project hosted under
  // florianlepont.github.io, not just this one.
  const base = import.meta.env.BASE_URL ?? '/';
  const cookiePath = base.endsWith('/') ? base : `${base}/`;

  document
    .querySelectorAll<HTMLAnchorElement>('.language-switcher .switcher-link')
    .forEach((link) => {
      link.addEventListener('click', () => {
        const locale = link.dataset.locale;
        if (locale) {
          document.cookie = `${COOKIE_NAME}=${locale}; path=${cookiePath}; max-age=31536000; SameSite=Lax; Secure`;
        }
      });
    });
</script>
