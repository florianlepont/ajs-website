---
// Gallery listing card (UI-SPEC Layout Notes + Color "Documented exception —
// Gallery title panels"): the whole card is a single link to the gallery's
// detail page; a pink accent panel (--color-accent) overlaps the lower
// portion of the 1:1 cover thumbnail and carries the Display-role title, per
// the reference's "bold color panel + ink type over photography" motif.
import { getRelativeLocaleUrl } from 'astro:i18n';
import { thumbnailUrl } from '../lib/image';
import type { Gallery } from '../lib/sanity';

interface Props {
  gallery: Gallery;
}

const { gallery } = Astro.props;
const locale = Astro.currentLocale === 'en' ? 'en' : 'fr';

const href = getRelativeLocaleUrl(locale, `galleries/${gallery.slug}`);
const cover = gallery.images[0];
const coverSrc = thumbnailUrl(cover, 600);
// WR-03: alt text is Studio-required (D-02), but a document written outside
// the Studio's publish-time validation could still be partially populated.
const coverAlt = cover.alt?.[locale] ?? '';
const ctaSuffix = locale === 'en' ? ' — View gallery' : ' — Voir la galerie';
---

<a href={href} class="gallery-card">
  <img
    src={coverSrc}
    width="600"
    height="600"
    alt={coverAlt}
    loading="lazy"
    decoding="async"
    class="gallery-card__cover"
  />
  <span class="gallery-card__panel">
    <span class="gallery-card__title">{gallery.title}</span>
  </span>
  <span class="sr-only">{ctaSuffix}</span>
</a>

<style>
  .gallery-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--color-ink);
  }

  .gallery-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .gallery-card__cover {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .gallery-card:hover .gallery-card__cover {
    transform: scale(1.02);
  }

  .gallery-card__panel {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: block;
    background: var(--color-accent);
    padding: var(--space-lg) var(--space-xl);
    transition: filter 0.2s ease;
  }

  .gallery-card:hover .gallery-card__panel,
  .gallery-card:focus-visible .gallery-card__panel {
    filter: brightness(1.05);
  }

  .gallery-card__title {
    display: block;
    font-size: var(--text-display-size); /* Display role: fixed 32px, not fluid */
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 1.2;
    color: var(--color-ink);
  }
</style>
