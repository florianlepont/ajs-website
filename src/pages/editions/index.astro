---
// French Éditions overview: an asymmetric "Poster Grid" of full-bleed photo
// tiles, grouped by 3 (hero + up to 2 stacked smalls, side alternating by
// group index) — the sketch-approved layout (D-01 through D-04,
// 12-CONTEXT.md; quick task 260723-txi). Mirrors the shared "editorial page"
// shell conventions established by about.astro (top hairline + eyebrow +
// h1), but the grid itself is a genuinely new pattern — there is no
// gallery-page equivalent to mirror (12-PATTERNS.md).
// Mirrors src/pages/en/editions/index.astro — only import depth and locale
// differ.
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getEditions } from '../../lib/sanity';
import type { Edition } from '../../lib/sanity';
import { thumbnailUrl, responsiveThumbnailSrcSet } from '../../lib/image';

const locale = 'fr' as const;
const editions = await getEditions();

// Chunk éditions into groups of 3 IN EXISTING orderRank ORDER — never
// re-sort/re-rank/re-fetch. Hero = first item of each group; the rest are
// smalls. Side alternates left/right by group index (group 0 = left).
const editionGroups: Edition[][] = [];
for (let i = 0; i < editions.length; i += 3) {
  editionGroups.push(editions.slice(i, i + 3));
}

const seoTitle = 'Éditions — Atelier Jacqueline Suzanne';
const seoDescription =
  "Découvrez les éditions papier de Romane Lepont — zines et livres publiés par l'Atelier Jacqueline Suzanne.";
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <article class="editions-list">
    <header class="editions-list__header">
      <p class="editions-list__eyebrow">Atelier Jacqueline Suzanne</p>
      <h1>Éditions</h1>
    </header>

    {
      editions.length === 0 ? (
        <EmptyState
          heading="Éditions à venir"
          body="De nouvelles éditions seront bientôt visibles ici. Revenez prochainement."
          variant="bold"
        />
      ) : (
        <div class="editions-grid">
          {editionGroups.map((group, g) => (
            <div class="editions-grid__group" data-size={group.length} data-side={g % 2 === 0 ? 'left' : 'right'}>
              {group.map((edition, idx) => {
                const alt = edition.leadPhoto.alt?.[locale] ?? '';
                return (
                  <a
                    class:list={['tile', idx === 0 ? 'tile--hero' : 'tile--small']}
                    href={getRelativeLocaleUrl(locale, `editions/${edition.slug}`)}
                  >
                    <img
                      src={thumbnailUrl(edition.leadPhoto, 600)}
                      srcset={responsiveThumbnailSrcSet(edition.leadPhoto)}
                      sizes={idx === 0 ? '(max-width: 800px) 100vw, 58vw' : '(max-width: 800px) 100vw, 40vw'}
                      alt={alt}
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="tile__scrim" aria-hidden="true" />
                    <div class="tile__body">
                      <span class="tile__title">{edition.title}</span>
                      <p class="tile__statement">{edition.statement?.[locale] ?? ''}</p>
                    </div>
                    <span class="sr-only"> — Voir l'édition</span>
                  </a>
                );
              })}
            </div>
          ))}
        </div>
      )
    }
  </article>
</BaseLayout>

<style>
  .editions-list {
    width: min(100%, var(--editorial-page-max));
    margin: 0 auto;
    padding: var(--editorial-page-padding-block) var(--editorial-page-padding-inline);
  }

  .editions-list__header {
    padding-top: var(--space-md);
    border-top: var(--border-hairline) solid var(--color-ink);
    margin-bottom: var(--space-2xl);
  }

  .editions-list__eyebrow {
    margin: 0;
    font-size: var(--text-label-size);
    font-weight: var(--weight-semibold);
    line-height: var(--text-label-leading);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .editions-list h1 {
    margin: var(--space-md) 0 0;
    font-size: var(--editorial-page-title-size);
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .editions-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .editions-grid__group {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 16vw;
    gap: var(--space-md);
  }

  .tile {
    position: relative;
    overflow: hidden;
    display: block;
    color: var(--gray-0);
    text-decoration: none;
    border: var(--border-hairline) solid var(--color-ink);
    background: var(--color-ink);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .tile:hover {
    transform: translate(-4px, -4px);
    box-shadow: 6px 6px 0 var(--color-ink);
  }

  .tile:focus-visible {
    transform: translate(-4px, -4px);
    box-shadow: 6px 6px 0 var(--color-ink);
    outline: 2px solid var(--color-accent);
    outline-offset: var(--focus-ring-offset);
  }

  .tile img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .tile:hover img {
    transform: scale(1.04);
  }

  .tile__scrim {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 60%;
    background: linear-gradient(to top, rgba(26, 26, 26, 0.9), rgba(26, 26, 26, 0));
  }

  .tile__body {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: var(--space-lg);
  }

  .tile__title {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    line-height: 0.95;
    margin-bottom: var(--space-xs);
  }

  .tile--hero .tile__title {
    font-size: clamp(28px, 4.5vw, 48px);
  }

  .tile--small .tile__title {
    font-size: clamp(20px, 2.6vw, 28px);
  }

  .tile__statement {
    font-size: var(--text-body-size);
    line-height: 1.4;
    max-width: 40ch;
    opacity: 0.9;
    margin: 0;
  }

  .tile--small .tile__statement {
    display: none;
  }

  .editions-grid__group[data-size='3'][data-side='left'] .tile:nth-child(1) {
    grid-column: 1 / 8;
    grid-row: 1 / 3;
  }

  .editions-grid__group[data-size='3'][data-side='left'] .tile:nth-child(2) {
    grid-column: 8 / 13;
    grid-row: 1 / 2;
  }

  .editions-grid__group[data-size='3'][data-side='left'] .tile:nth-child(3) {
    grid-column: 8 / 13;
    grid-row: 2 / 3;
  }

  .editions-grid__group[data-size='3'][data-side='right'] .tile:nth-child(1) {
    grid-column: 6 / 13;
    grid-row: 1 / 3;
  }

  .editions-grid__group[data-size='3'][data-side='right'] .tile:nth-child(2) {
    grid-column: 1 / 6;
    grid-row: 1 / 2;
  }

  .editions-grid__group[data-size='3'][data-side='right'] .tile:nth-child(3) {
    grid-column: 1 / 6;
    grid-row: 2 / 3;
  }

  .editions-grid__group[data-size='2'][data-side='left'] .tile:nth-child(1) {
    grid-column: 1 / 8;
    grid-row: 1 / 3;
  }

  .editions-grid__group[data-size='2'][data-side='left'] .tile:nth-child(2) {
    grid-column: 8 / 13;
    grid-row: 1 / 2;
  }

  .editions-grid__group[data-size='2'][data-side='right'] .tile:nth-child(1) {
    grid-column: 6 / 13;
    grid-row: 1 / 3;
  }

  .editions-grid__group[data-size='2'][data-side='right'] .tile:nth-child(2) {
    grid-column: 1 / 6;
    grid-row: 1 / 2;
  }

  .editions-grid__group[data-size='1'] {
    grid-auto-rows: 11vw;
  }

  .editions-grid__group[data-size='1'] .tile:nth-child(1) {
    grid-column: 1 / 13;
    grid-row: 1 / 2;
  }

  @media (max-width: 800px) {
    .editions-grid__group,
    .editions-grid__group[data-size='1'] {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }

    .editions-grid__group .tile {
      grid-column: 1 !important;
      grid-row: auto !important;
      aspect-ratio: 3 / 4;
    }

    .tile--hero .tile__title {
      font-size: clamp(28px, 9vw, 40px);
    }
  }
</style>
