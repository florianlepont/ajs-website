---
// French About page: biography/practice content is managed by the published
// Sanity aboutPage singleton, with safe build-time fallbacks.
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAboutPage, getSiteSettings } from '../lib/sanity';
import { resolveSiteCopy } from '../lib/site-config';
import { fullSizeUrl } from '../lib/image';

const siteCopy = resolveSiteCopy(await getSiteSettings(), 'fr');
const about = await getAboutPage();
const biography = about?.biography?.fr ?? 'Le texte de présentation de Romane sera bientôt disponible ici.';
const practice = about?.practice?.fr ?? "Informations sur l'atelier et la pratique de Romane à venir prochainement.";
const medium = about?.medium?.fr ?? 'Précisions sur le médium et la technique à venir.';
const seoTitle = about?.seo?.title?.fr ?? 'À propos — Atelier Jacqueline Suzanne';
const seoDescription = about?.seo?.description?.fr ?? biography;
const socialImage = about?.seo?.image ? fullSizeUrl(about.seo.image, 1200) : undefined;
---

<BaseLayout title={seoTitle} description={seoDescription} socialImage={socialImage}>
  <div class="about-page">
    <h1>À propos</h1>
    <p>{biography}</p>
    <h2>Atelier &amp; pratique</h2>
    <p>{practice}</p>
    <p>{medium}</p>
    <p>
      Suivez le travail de Romane sur Instagram :
      <a
        href={siteCopy.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
      >{siteCopy.instagramLabel}<span class="sr-only"> (nouvelle fenêtre)</span></a>
    </p>
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
  }

  .about-page h1 {
    font-size: var(--text-display-size); /* Display role */
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 1.2;
    margin: 0 0 var(--space-xl);
  }

  .about-page h2 {
    font-size: var(--text-heading-size); /* Heading role */
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 1.2;
    margin: var(--space-2xl) 0 var(--space-md);
  }

  .about-page p {
    font-size: var(--text-body-size); /* Body role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    margin: 0 0 var(--space-md);
  }

</style>
