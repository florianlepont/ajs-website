---
// English Contact page (CONT-01, CONT-02): identical structure to
// src/pages/contact.astro; only import depth and copy differ.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getSiteSettings } from '../../lib/sanity';
import { resolveSiteCopy } from '../../lib/site-config';

const locale = 'en' as const;
const siteCopy = resolveSiteCopy(await getSiteSettings(), locale);
---

<BaseLayout title="Contact — Atelier Jacqueline Suzanne">
  <div class="contact-page">
    <h1>Contact</h1>
    <p class="contact-page__lead">A question, or an idea for a collaboration? Get in touch.</p>
    <p class="contact-page__social">
      You can also follow me on Instagram:
      <a
        href={siteCopy.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
      >{siteCopy.instagramLabel}<span class="sr-only"> (opens in new tab)</span></a>
    </p>
    <ContactForm locale={locale} />
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
  }

  .contact-page h1 {
    font-size: var(--text-display-size); /* Display role */
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 1.2;
    margin: 0 0 var(--space-xl);
  }

  .contact-page__lead {
    font-size: var(--text-body-size); /* Body role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    margin: 0 0 var(--space-2xl);
  }

  .contact-page__social {
    font-size: var(--text-body-size); /* Body role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    margin: 0 0 var(--space-2xl);
  }
</style>
