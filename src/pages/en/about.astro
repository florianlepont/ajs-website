---
// English About page: mirrors the French Sanity-managed page.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAboutPage, getSiteSettings } from '../../lib/sanity';
import { resolveSiteCopy } from '../../lib/site-config';
import { fullSizeUrl } from '../../lib/image';

const siteCopy = resolveSiteCopy(await getSiteSettings(), 'en');
const about = await getAboutPage();
const biography = about?.biography?.en ?? "Romane's biography will be available here soon.";
const practice = about?.practice?.en ?? "Information about Romane's studio and practice is coming soon.";
const medium = about?.medium?.en ?? 'Details on medium and technique are coming soon.';
const seoTitle = about?.seo?.title?.en ?? 'About — Atelier Jacqueline Suzanne';
const seoDescription = about?.seo?.description?.en ?? biography;
const socialImage = about?.seo?.image ? fullSizeUrl(about.seo.image, 1200) : undefined;
---

<BaseLayout title={seoTitle} description={seoDescription} socialImage={socialImage}>
  <div class="about-page">
    <h1>About</h1>
    <p>{biography}</p>
    <h2>Studio &amp; practice</h2>
    <p>{practice}</p>
    <p>{medium}</p>
    <p>
      Follow Romane's work on Instagram:
      <a
        href={siteCopy.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
      >{siteCopy.instagramLabel}<span class="sr-only"> (opens in new tab)</span></a>
    </p>
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
  }

  .about-page h1 {
    font-size: var(--text-display-size); /* Display role */
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 1.2;
    margin: 0 0 var(--space-xl);
  }

  .about-page h2 {
    font-size: var(--text-heading-size); /* Heading role */
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 1.2;
    margin: var(--space-2xl) 0 var(--space-md);
  }

  .about-page p {
    font-size: var(--text-body-size); /* Body role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    margin: 0 0 var(--space-md);
  }

</style>
