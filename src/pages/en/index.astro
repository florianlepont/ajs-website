---
// English homepage (D-10 placeholder content). Identical layout to the
// French homepage — only the locale/copy differs (UI-SPEC Layout Notes).
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteSettings } from '../../lib/sanity';

const siteSettings = await getSiteSettings();
const welcomeHeading = siteSettings?.welcomeHeading?.en ?? '';
const welcomeBody = siteSettings?.welcomeBody?.en ?? '';
---

<BaseLayout title="Atelier Jacqueline Suzanne">
  <div class="welcome">
    <h1>{welcomeHeading}</h1>
    <p>{welcomeBody}</p>
  </div>
</BaseLayout>

<style>
  .welcome {
    max-width: 640px;
    margin: 0 auto;
    padding: 48px 16px; /* 2xl vertical, md horizontal */
    text-align: center;
  }

  .welcome h1 {
    font-size: 32px; /* Display role */
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .welcome p {
    font-size: 16px; /* Body role */
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
  }
</style>
