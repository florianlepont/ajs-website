---
// English gallery listing (PORT-01). Identical layout to the French listing
// at src/pages/galleries/index.astro — only import depth and copy differ.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GalleryGrid from '../../../components/GalleryGrid.astro';
import GalleryCard from '../../../components/GalleryCard.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { getGalleries } from '../../../lib/sanity';

const galleries = await getGalleries();
---

<BaseLayout title="Galleries — Atelier Jacqueline Suzanne">
  {
    galleries.length > 0 ? (
      <div class="galleries-page">
        <h1>Galleries</h1>
        <GalleryGrid>
          {galleries.map((gallery) => (
            <GalleryCard gallery={gallery} />
          ))}
        </GalleryGrid>
      </div>
    ) : (
      <EmptyState heading="Galleries coming soon" body="New work will appear here shortly. Check back soon." />
    )
  }
</BaseLayout>

<style>
  .galleries-page {
    padding: var(--space-2xl) var(--space-md);
  }

  /* D-16/UI-SPEC Typography: Display is a site-wide fixed 32px role, not a
     fluid/responsive font-size mechanism. */
  .galleries-page h1 {
    font-size: var(--text-display-size);
    font-weight: var(--text-display-weight);
    line-height: var(--text-display-leading);
    font-family: var(--text-display-family);
    margin: 0 0 var(--space-xl);
  }
</style>
