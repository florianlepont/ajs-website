---
// English gallery detail page (PORT-01/PORT-03). Identical structure to the
// French detail page at src/pages/galleries/[slug].astro — only import depth
// and locale key differ.
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GalleryGrid from '../../../components/GalleryGrid.astro';
import Lightbox from '../../../components/Lightbox.astro';
import { getGalleries } from '../../../lib/sanity';
import { thumbnailUrl, fullSizeUrl } from '../../../lib/image';
import type { Gallery } from '../../../lib/sanity';

export const getStaticPaths = (async () => {
  const galleries = await getGalleries();
  return galleries.map((gallery) => ({
    params: { slug: gallery.slug },
    props: { gallery },
  }));
}) satisfies GetStaticPaths;

interface Props {
  gallery: Gallery;
}

const { gallery } = Astro.props;
const locale = 'en' as const;
// WR-03: statement is Studio-required (fr/en) per 02-01's schema validation,
// but a document written outside the Studio's publish-time validation could
// still be partially populated mid-edit.
const statement = gallery.statement?.[locale] ?? '';
// D-07/UI-SPEC Layout Notes: hero-scrim uses the gallery's cover photo
// (images[0]) at full size, same helper the Lightbox uses for its slides.
const heroImage = gallery.images[0];
const heroSrc = fullSizeUrl(heroImage, 2000);
const heroAlt = heroImage.alt?.[locale] ?? '';
const seoTitle = gallery.seo?.title?.[locale] ?? `${gallery.title} — Atelier Jacqueline Suzanne`;
const seoDescription = gallery.seo?.description?.[locale] ?? statement;
const socialImage = fullSizeUrl(gallery.seo?.image ?? heroImage, 1200);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: gallery.title,
  description: seoDescription,
  url: Astro.url.toString(),
  inLanguage: 'en',
  creator: { '@type': 'Person', name: 'Romane Lepont' },
  image: gallery.images.map((image) => ({
    '@type': 'ImageObject',
    contentUrl: fullSizeUrl(image, 2000),
    caption: image.alt?.en ?? '',
    creditText: image.rights?.credit ?? 'Romane Lepont',
    copyrightNotice: image.rights?.copyrightNotice ?? '© Romane Lepont — Tous droits réservés',
  })),
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  socialImage={socialImage}
  noIndex={gallery.seo?.noIndex}
  structuredData={structuredData}
  headerVariant="transparent"
>
  <div class="gallery-detail">
    <div class="gallery-detail__hero">
      <img
        src={heroSrc}
        alt={heroAlt}
        class="gallery-detail__hero-img"
        loading="eager"
        decoding="async"
      />
      <div class="gallery-detail__hero-scrim" aria-hidden="true"></div>
      <h1 class="gallery-detail__hero-title">{gallery.title}</h1>
    </div>
    <div class="gallery-detail__content">
      <p class="gallery-detail__statement">{statement}</p>
      {
        // Bug fix (gallery-thumb-grid-confusion): images[0] is already shown
        // full-bleed as the hero above — rendering it again as the grid's
        // first thumbnail duplicated it back-to-back. Skip index 0 here;
        // it's still reachable in the Lightbox via prev/next wraparound
        // since Lightbox below still receives the FULL gallery.images array.
        gallery.images.length > 1 && (
          <GalleryGrid>
            {
              gallery.images.slice(1).map((img, i) => {
                const index = i + 1;
                return (
                  <button
                    type="button"
                    class="gallery-detail__thumb-button"
                    data-gallery-thumb
                    data-index={index}
                    aria-label={`View full size, image ${index + 1} of ${gallery.images.length}`}
                  >
                    <img
                      src={thumbnailUrl(img, 600)}
                      width="600"
                      height="600"
                      alt=""
                      loading="lazy"
                      decoding="async"
                      class="gallery-detail__thumb"
                    />
                  </button>
                );
              })
            }
          </GalleryGrid>
        )
      }
    </div>
  </div>
  <Lightbox images={gallery.images} locale={locale} />
</BaseLayout>

<style>
  .gallery-detail {
    padding: 0 0 var(--space-2xl);
  }

  /* D-07: full-bleed hero photo + dark gradient scrim (matches the homepage
     carousel's technique) with a white bottom-left Display title, under
     the transparent header variant. */
  .gallery-detail__hero {
    position: relative;
    height: 70vh;
    min-height: 420px;
    overflow: hidden;
  }

  .gallery-detail__hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-detail__hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.15) 45%, rgba(0, 0, 0, 0) 70%);
    pointer-events: none;
  }

  .gallery-detail__hero-title {
    position: absolute;
    left: var(--space-xl);
    bottom: var(--space-xl);
    right: var(--space-xl);
    z-index: 3;
    margin: 0;
    font-size: var(--text-display-size); /* Display role: fixed 32px */
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 1.2;
    color: #FFFFFF;
  }

  .gallery-detail__content {
    padding: var(--space-2xl) var(--space-md) 0;
  }

  .gallery-detail__statement {
    max-width: 640px;
    font-size: 16px; /* Body role */
    font-weight: var(--weight-regular);
    line-height: 1.5;
    margin: 0 0 var(--space-2xl);
  }

  .gallery-detail__thumb-button {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  .gallery-detail__thumb-button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .gallery-detail__thumb {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
</style>
