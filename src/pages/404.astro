---
// Bilingual 404 page (RESEARCH.md "Don't Hand-Roll" — Apache does not
// auto-wire Astro's prerendered 404 into its own error handling; this page
// is paired with public/.htaccess's `ErrorDocument 404 /404.html`). Renders
// through the same BaseLayout chrome as every other page.
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

// CR-01: astro:i18n's URL helpers are the only thing that apply the
// deployed `base` (e.g. "/ajs-website/" on GitHub Pages) to a link — plain
// literal href strings are never rewritten. Every other "return home" link
// in the codebase (BaseLayout's nav, LanguageSwitcher) already goes through
// getRelativeLocaleUrl(); this page must too, or a visitor who lands here
// under a non-root base gets bounced off the site entirely.
const frHome = getRelativeLocaleUrl('fr', '');
const enHome = getRelativeLocaleUrl('en', '');
---

<BaseLayout title="Page introuvable / Page not found">
  <div class="not-found">
    <section>
      <h1>Page introuvable</h1>
      <p>Page introuvable. Retournez à l'accueil.</p>
      <p><a href={frHome}>Retourner à l'accueil</a></p>
    </section>
    <section>
      <h2>Page not found</h2>
      <p>Page not found. Return home.</p>
      <p><a href={enHome}>Return home</a></p>
    </section>
  </div>
</BaseLayout>

<style>
  .not-found {
    max-width: 640px;
    margin: 0 auto;
    padding: 48px 16px; /* 2xl vertical, md horizontal */
    text-align: center;
  }

  .not-found h1,
  .not-found h2 {
    font-size: 20px; /* Heading role */
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .not-found p {
    font-size: 16px; /* Body role */
    font-weight: 400;
    line-height: 1.5;
    margin: 0 0 16px;
  }

  .not-found a {
    color: var(--color-accent);
  }
</style>
