---
// French homepage (root, D-10 placeholder content). Copy is sourced from the
// Sanity siteSettings singleton via BaseLayout/getSiteSettings — no hardcoded
// chrome or welcome strings, no placeholder CTA button (UI-SPEC: the first
// real CTA arrives in Phase 2).
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings } from '../lib/sanity';

const siteSettings = await getSiteSettings();
const welcomeHeading = siteSettings?.welcomeHeading?.fr ?? '';
const welcomeBody = siteSettings?.welcomeBody?.fr ?? '';
---

<BaseLayout title="Atelier Jacqueline Suzanne">
  <div class="welcome">
    <h1>{welcomeHeading}</h1>
    <p>{welcomeBody}</p>
  </div>
</BaseLayout>

<style>
  .welcome {
    max-width: 640px;
    margin: 0 auto;
    padding: 48px 16px; /* 2xl vertical, md horizontal */
    text-align: center;
    container-type: inline-size; /* required for the Display role's cqi clamp() to resolve */
  }

  .welcome h1 {
    font-size: clamp(2.5rem, 12cqi, 6.5rem); /* Display role */
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  .welcome p {
    font-size: 16px; /* Body role */
    font-weight: 300;
    line-height: 1.5;
    margin: 0;
  }
</style>
