---
// French homepage (D-08–D-12): the real gallery entry point — hero carousel
// + grid toggle, replacing Phase 1's placeholder. Only galleries with real
// migrated photos appear (D-12 — filtered generically by `images.length > 0`,
// not a hardcoded slug denylist, so it adapts automatically as more
// galleries are migrated). Homepage copy is hardcoded (UI-SPEC "Homepage
// intro copy source" decision) — this page does NOT read
// welcomeHeading/welcomeBody.
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeCarousel from '../components/HomeCarousel.astro';
import { getGalleries } from '../lib/sanity';
import { fullSizeUrl, thumbnailUrl } from '../lib/image';

const locale = 'fr' as const;

const galleries = (await getGalleries())
  .filter((gallery) => gallery.images.length > 0)
  .map((gallery) => {
    const cover = gallery.images[0];
    return {
      slug: gallery.slug,
      title: gallery.title,
      heroSrc: fullSizeUrl(cover),
      gridSrc: thumbnailUrl(cover, 600),
      // WR-03: alt text is Studio-required (D-02), but a document written
      // outside the Studio's publish-time validation could still be
      // partially populated.
      alt: cover.alt?.[locale] ?? '',
    };
  });
---

<BaseLayout title="Atelier Jacqueline Suzanne" headerVariant="none">
  <HomeCarousel locale={locale} galleries={galleries} />
</BaseLayout>
