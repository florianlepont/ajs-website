---
// French Contact page (CONT-01, CONT-02): mounts the ContactForm island at
// the bottom of BaseLayout's body, passing `locale` as a build-time prop —
// same mount style as <Lightbox images={...} locale={locale} /> in
// src/pages/galleries/[slug].astro. Mirrors src/pages/about.astro's
// hardcoded-content page shape; only import depth and copy differ from
// src/pages/en/contact.astro.
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { getContactPage } from '../lib/sanity';
import { fullSizeUrl } from '../lib/image';

const locale = 'fr' as const;
const contact = await getContactPage();
const intro = contact?.intro?.fr ?? 'Une question, une envie de collaboration ? Écrivez-moi.';
const publicEmail = contact?.publicEmail ?? 'contact@atelierjacquelinesuzanne.fr';
const location = contact?.location?.fr;
const availability = contact?.availability?.fr;
const professionalLinks = (contact?.professionalLinks ?? []).filter((link) => link.url && link.label?.fr);
const instagramLink = professionalLinks.find((link) => link.url?.includes('instagram.com'));
const otherProfessionalLinks = professionalLinks.filter((link) => link !== instagramLink);
const seoTitle = contact?.seo?.title?.fr ?? 'Contact — Atelier Jacqueline Suzanne';
const seoDescription = contact?.seo?.description?.fr ?? intro;
const socialImage = contact?.seo?.image ? fullSizeUrl(contact.seo.image, 1200) : undefined;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact',
  description: intro,
  mainEntity: {
    '@type': 'Person',
    name: 'Romane Lepont',
    email: publicEmail,
  },
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  socialImage={socialImage}
  noIndex={contact?.seo?.noIndex}
  structuredData={structuredData}
>
  <div class="contact-page">
    <section class="contact-page__intro" aria-labelledby="contact-title">
      <p class="contact-page__eyebrow">Atelier Jacqueline Suzanne</p>
      <h1 id="contact-title">Contact</h1>
      <p class="contact-page__lead">{intro}</p>

      <div class="contact-page__details">
        <div class="contact-page__channels">
          <a class="contact-page__detail" href={`mailto:${publicEmail}`}>
            <span class="contact-page__detail-copy">
              <span class="contact-page__detail-heading">
                <span class="contact-page__number" aria-hidden="true">02</span>
                <span class="contact-page__label">E-mail</span>
              </span>
              <span class="contact-page__value">{publicEmail}</span>
            </span>
            <span class="contact-page__arrow" aria-hidden="true">↗</span>
          </a>
          {instagramLink && (
            <a
              class="contact-page__detail contact-page__social"
              href={instagramLink.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="contact-page__detail-copy">
                <span class="contact-page__detail-heading">
                  <span class="contact-page__number" aria-hidden="true">03</span>
                  <span class="contact-page__label">Instagram</span>
                </span>
                <span class="contact-page__value">{instagramLink.label?.fr}</span>
              </span>
              <span class="contact-page__arrow" aria-hidden="true">↗</span>
              <span class="sr-only"> (nouvelle fenêtre)</span>
            </a>
          )}
        </div>
        {(location || availability) && (
          <div class="contact-page__detail contact-page__detail--meta">
            {location && <p>{location}</p>}
            {availability && <p>{availability}</p>}
          </div>
        )}
        {otherProfessionalLinks.length > 0 && (
          <ul class="contact-page__links">
            {otherProfessionalLinks.map((link) => (
              <li>
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {link.label?.fr}<span class="sr-only"> (nouvelle fenêtre)</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

    <section class="contact-page__form-panel" aria-labelledby="contact-form-title">
      <div class="contact-page__form-heading">
        <p class="contact-page__step" aria-hidden="true">01</p>
        <div>
          <h2 id="contact-form-title">Écrivez-moi</h2>
          <p>Je vous répondrai dès que possible.</p>
        </div>
      </div>
      <ContactForm locale={locale} publicEmail={publicEmail} />
    </section>
  </div>
</BaseLayout>

<style>
  .contact-page {
    --color-accent: var(--color-ink);

    display: grid;
    grid-template-columns: minmax(280px, 0.8fr) minmax(440px, 1.2fr);
    gap: var(--editorial-page-column-gap);
    width: min(100%, var(--editorial-page-max));
    margin: 0 auto;
    padding: var(--editorial-page-padding-block) var(--editorial-page-padding-inline);
  }

  .contact-page__intro {
    align-self: start;
    padding-top: var(--space-md);
    border-top: var(--border-hairline) solid var(--color-ink);
  }

  .contact-page__eyebrow,
  .contact-page__label,
  .contact-page__number,
  .contact-page__step {
    margin: 0;
    font-size: var(--text-label-size);
    font-weight: var(--weight-semibold);
    line-height: var(--text-label-leading);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-page h1 {
    margin: var(--space-md) 0 var(--space-lg);
    font-size: var(--editorial-page-title-size);
    font-weight: var(--weight-semibold);
    font-family: var(--font-display);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .contact-page__lead {
    max-width: 28ch;
    margin: 0;
    font-size: var(--editorial-page-lead-size);
    font-weight: var(--weight-regular);
    line-height: var(--editorial-page-lead-leading);
  }

  .contact-page__details {
    display: grid;
    gap: var(--space-lg);
    margin-top: clamp(var(--space-xl), 5vw, var(--space-3xl));
    border-top: var(--border-hairline) solid var(--color-ink);
  }

  .contact-page__channels {
    display: grid;
  }

  .contact-page__detail {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    color: var(--color-ink);
    border-bottom: var(--border-hairline) solid var(--color-border);
    text-decoration: none;
    transition:
      padding 160ms ease,
      border-color 160ms ease;
  }

  .contact-page__detail:hover,
  .contact-page__detail:focus-visible {
    padding-right: var(--space-sm);
    padding-left: var(--space-sm);
    border-color: var(--color-accent);
  }

  .contact-page__detail-copy,
  .contact-page__value {
    display: block;
  }

  .contact-page__detail-heading {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: var(--space-sm);
    align-items: baseline;
  }

  .contact-page__value {
    max-width: 100%;
    margin-top: var(--space-xs);
    padding-left: calc(24px + var(--space-sm));
    font-size: clamp(16px, 1.25vw, 18px);
    line-height: 1.3;
    color: var(--color-accent);
    overflow-wrap: anywhere;
  }

  .contact-page__arrow {
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    color: var(--color-accent);
    border: var(--border-hairline) solid var(--color-accent);
    transition: transform 160ms ease;
  }

  .contact-page__detail:hover .contact-page__arrow,
  .contact-page__detail:focus-visible .contact-page__arrow {
    transform: translate(2px, -2px);
  }

  .contact-page__detail--meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xs);
    padding: 0;
    border: 0;
  }

  .contact-page__detail--meta p {
    margin: 0;
    line-height: var(--text-body-leading);
  }

  .contact-page__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin: var(--space-md) 0 0;
    padding: 0;
    list-style: none;
  }

  .contact-page__form-panel {
    align-self: start;
    padding: clamp(var(--space-lg), 4vw, var(--space-2xl));
    border: var(--border-hairline) solid var(--color-ink);
    box-shadow: 10px 10px 0 var(--color-accent);
  }

  .contact-page__form-heading {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: var(--border-hairline) solid var(--color-border);
  }

  .contact-page__step {
    color: var(--color-accent);
  }

  .contact-page__form-heading h2 {
    margin: 0 0 var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--editorial-page-section-title-size);
    font-weight: var(--weight-semibold);
    line-height: var(--editorial-page-section-title-leading);
  }

  .contact-page__form-heading p {
    margin: 0;
    line-height: var(--text-body-leading);
  }

  @media (max-width: 800px) {
    .contact-page {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .contact-page__lead {
      max-width: 34ch;
    }
  }

  @media (max-width: 480px) {
    .contact-page {
      padding-top: var(--space-xl);
      padding-bottom: var(--space-3xl);
    }

    .contact-page h1 {
      font-size: clamp(38px, 13vw, 52px);
    }

    .contact-page__form-panel {
      padding: var(--space-lg) var(--space-md);
      box-shadow: 6px 6px 0 var(--color-accent);
    }

    .contact-page__form-heading {
      gap: var(--space-md);
    }
  }
</style>
