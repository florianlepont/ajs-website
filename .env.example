# Sanity Content Lake — build-time only. Never exposed to the browser.
# Copy this file to .env and fill in real values (never commit .env).

# Sanity project ID (sanity.io/manage → project → Project ID)
SANITY_PROJECT_ID=

# Dataset name (e.g. "production")
SANITY_DATASET=

# Read-only (Viewer) API token for build-time fetches.
# Create via: npx sanity tokens add "Build-time Viewer (read-only)" --role=viewer --yes
# (run from the sanity/ Studio directory, requires an authenticated `sanity login` session)
SANITY_API_READ_TOKEN=

# Web3Forms access key (CONT-01) — relays the contact form POST as an email
# to Romane's atelierjacquelinesuzanne.fr inbox (03-RESEARCH.md D-08). Obtain
# via signup at web3forms.com using that exact mailbox (NOT the old site's
# reversed-word-order jacquelinesuzanneatelier.fr address).
#
# MUST carry the PUBLIC_ prefix — unlike the SANITY_* vars above, this one is
# intentionally inlined into client-shipped JS (Astro/Vite's documented
# mechanism, see docs.astro.build/en/guides/environment-variables/), because
# ContactForm.astro's <script> calls the Web3Forms API directly from the
# browser. This is by design, not a leaked secret: Web3Forms' own docs embed
# this key in a plain <input type="hidden"> in their canonical HTML example
# — it grants no account access. Automated tests mock the network, so no real
# key is needed for CI; the real key is only required for live delivery.
PUBLIC_WEB3FORMS_ACCESS_KEY=
